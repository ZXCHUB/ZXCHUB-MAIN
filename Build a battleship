local dragging, dragInput, dragStart, startPos

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        local delta = dragInput.Position - dragStart
        MainFrame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

local function GetNearestTarget(folder, filterFunc, excludeNames)
    local nearest, dist = nil, math.huge
    local hrpPos = HumanoidRootPart.Position
    
    for _, model in ipairs(folder:GetChildren()) do
        if model:IsA("Model") then
            local skip = false
            if excludeNames then
                for _, ex in ipairs(excludeNames) do
                    if model.Name == ex then skip = true break end
                end
            end
            if skip then continue end
            
            if filterFunc and not filterFunc(model) then continue end
            
            local primary = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart")
            if primary then
                local d = (primary.Position - hrpPos).Magnitude
                if d < dist then
                    dist = d
                    nearest = primary
                end
            end
        end
    end
    return nearest
end

local spawnDebounce = false
local SpawnBoatRemote = ReplicatedStorage:WaitForChild("Events", 5):WaitForChild("SpawnBoat", 5)

local function CheckAndSpawnBoat()
    if not SpawnBoatRemote then return end

    local myBoatName = LocalPlayer.Name .. "_Boat"
    if Workspace.ActiveBoats:FindFirstChild(myBoatName) then
        return
    end

    if spawnDebounce then return end
    spawnDebounce = true

    pcall(function()
        SpawnBoatRemote:FireServer()
        SpawnBoatRemote:FireServer("Default")
        SpawnBoatRemote:FireServer("Boat")
        SpawnBoatRemote:FireServer(1)
        SpawnBoatRemote:FireServer("")
    end)

    task.delay(2, function()
        spawnDebounce = false
    end)
end

RunService.Heartbeat:Connect(function()
    local anyAutoFarm = Settings.AutoFarmNPC or Settings.AutoFarmPlayers
    
    if anyAutoFarm then
        CheckAndSpawnBoat()
    end
    
    if Settings.AutoFarmNPC then
        local filter = function(model) return model.Name == "NPC_Boat" end
        local target = GetNearestTarget(Workspace.ActiveBoats, filter, nil)
        if target then
            HumanoidRootPart.CFrame = target.CFrame * CFrame.new(0, -5, 0)
        end
    end
    
    if Settings.AutoFarmPlayers then
        local exclude = {LocalPlayer.Name .. "_Boat"}
        local target = GetNearestTarget(Workspace.ActiveBoats, nil, exclude)
        if target then
            HumanoidRootPart.CFrame = target.CFrame * CFrame.new(0, -5, 0)
        end
    end
    
    if Settings.RemoveCrates then
        for _, v in ipairs(Workspace.ActiveCrates:GetChildren()) do
            pcall(function() v:Destroy() end)
        end
    end
    
    if Settings.RemoveBarrels then
        for _, v in ipairs(Workspace.ExplosiveTanks:GetChildren()) do
            pcall(function() v:Destroy() end)
        end
    end
    
    if Settings.RemoveSpinningBlade then
        for _, v in ipairs(Workspace.Obstacles:GetChildren()) do
            if v.Name == "SpinningBlade" then
                pcall(function() v:Destroy() end)
            end
        end
    end
end)

