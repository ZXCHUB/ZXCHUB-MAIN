local function CreateToggle(parent, name, yOffset, callback)
    local toggleFrame = Instance.new("Frame")
    toggleFrame.Size = UDim2.new(1, 0, 0, 50)
    toggleFrame.Position = UDim2.new(0, 0, 0, yOffset)
    toggleFrame.BackgroundTransparency = 1
    toggleFrame.Parent = parent
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextSize = 16
    label.Font = Enum.Font.Gotham
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = toggleFrame
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 50, 0, 28)
    toggle.Position = UDim2.new(1, -60, 0.5, -14)
    toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
    toggle.Text = "OFF"
    toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggle.TextSize = 14
    toggle.Font = Enum.Font.GothamBold
    toggle.Parent = toggleFrame
    
    local togCorner = Instance.new("UICorner")
    togCorner.CornerRadius = UDim.new(0, 14)
    togCorner.Parent = toggle
    
    local enabled = false
    
    toggle.MouseButton1Click:Connect(function()
        enabled = not enabled
        if enabled then
            toggle.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
            toggle.Text = "ON"
            toggle.TextColor3 = Color3.new(1,1,1)
        else
            toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
            toggle.Text = "OFF"
            toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
        end
        callback(enabled)
    end)
    
    return toggleFrame
end

