    end
    local cb=Btn(row,UDim2.new(1,0,1,0),UDim2.new(0,0,0,0),C.bg0); cb.BackgroundTransparency=1
    cb.MouseButton1Click:Connect(function()
        local popW=isMobile and math.min(280,workspace.CurrentCamera.ViewportSize.X-16) or 260
        local popH=isMobile and 280 or 256
        local pop=Frame(GUI,UDim2.new(0,popW,0,popH),UDim2.new(0.5,-popW/2,0.5,-popH/2),C.bg0,8)
        pop.ZIndex=115; Stroke(pop,C.brd2,1)
        local hH=isMobile and 36 or 30
        local head=Frame(pop,UDim2.new(1,0,0,hH),UDim2.new(0,0,0,0),C.bg1)
        Frame(head,UDim2.new(1,0,0,2),UDim2.new(0,0,1,-2),C.acc)
        local hLbl=Lbl(head,"Color Picker",isMobile and 12 or 12,C.white,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
        hLbl.Size=UDim2.new(1,-40,1,0)
        local cX=Btn(head,UDim2.new(0,isMobile and 30 or 26,0,isMobile and 30 or 26),
            UDim2.new(1,-(isMobile and 33 or 29),0.5,-(isMobile and 15 or 13)),C.acc,4)
        Lbl(cX,"X",isMobile and 12 or 11,C.white,Enum.Font.GothamBold,Enum.TextXAlignment.Center)
        local prevH=isMobile and 44 or 38
        local prevF=Frame(pop,UDim2.new(1,-16,0,prevH),UDim2.new(0,8,0,hH+8), Color3.fromRGB(Flags[flag].r,Flags[flag].g,Flags[flag].b),6)
        Stroke(prevF,C.brd2,1)
        local hexLbl=Lbl(prevF,"",isMobile and 10 or 10,C.white,Enum.Font.GothamMedium,Enum.TextXAlignment.Center)
        local function RefreshAll()
            local fv=Flags[flag]
            local col=Color3.fromRGB(fv.r,fv.g,fv.b)
            prevF.BackgroundColor3=col; UpdateSwatch()
            hexLbl.Text=string.format("#%02X%02X%02X",fv.r,fv.g,fv.b)
            if callback then callback(fv.r,fv.g,fv.b) end
        end
        RefreshAll()
        local bodyY=hH+prevH+18
        local function ColorSlider(label,colorKey,yp,col)
            local slH=isMobile and 38 or 32
            local slC=Frame(pop,UDim2.new(1,-16,0,slH),UDim2.new(0,8,0,yp),C.bg0)
            slC.BackgroundTransparency=1
            local lH=isMobile and 16 or 14
            local sL=Lbl(slC,label,isMobile and 10 or 9,C.txt2,Enum.Font.GothamBold)
            sL.Size=UDim2.new(0,12,0,lH)
            local vLbl2=Lbl(slC,"",isMobile and 10 or 9,C.txt2,Enum.Font.GothamMedium,Enum.TextXAlignment.Right)
            vLbl2.Size=UDim2.new(0,26,0,lH); vLbl2.Position=UDim2.new(1,-26,0,0)
            local tY2=isMobile and 20 or 17
            local track2=Frame(slC,UDim2.new(1,0,0,5),UDim2.new(0,0,0,tY2),C.bg4,3)
            local fill2=Frame(track2,UDim2.new(0,0,1,0),UDim2.new(0,0,0,0),col,3)
            local t2Sz=isMobile and 12 or 10
            local thumb2=Frame(track2,UDim2.new(0,t2Sz,0,t2Sz),UDim2.new(0,-t2Sz/2,0.5,-t2Sz/2),C.white,t2Sz/2)
            Stroke(thumb2,C.brd2,1)
            local drag2=false
            local function SCV(v)
                local iv=math.clamp(math.floor(v+0.5),0,255)
                Flags[flag][colorKey]=iv
                local pct=iv/255
                fill2.Size=UDim2.new(pct,0,1,0)
                thumb2.Position=UDim2.new(pct,-t2Sz/2,0.5,-t2Sz/2)
                vLbl2.Text=tostring(iv); RefreshAll()
            end
            local function P2V2(ax)
                return 0+255*math.clamp((ax-track2.AbsolutePosition.X)/track2.AbsoluteSize.X,0,1)
            end
            SCV(Flags[flag][colorKey])
            track2.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    drag2=true; SCV(P2V2(i.Position.X)) end end)
            thumb2.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    drag2=true end end)
            UIS.InputChanged:Connect(function(i)
                if drag2 and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
                    SCV(P2V2(i.Position.X)) end end)
            UIS.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
                    drag2=false end end)
            return yp+slH+4
        end
        bodyY=ColorSlider("R","r",bodyY,Color3.fromRGB(200,50,50))
        bodyY=ColorSlider("G","g",bodyY,Color3.fromRGB(50,185,75))
        bodyY=ColorSlider("B","b",bodyY,Color3.fromRGB(55,115,220))
        cX.MouseButton1Click:Connect(function()
            local fv=Flags[flag]
            Toast("Color Picker", string.format("Color set: #%02X%02X%02X",fv.r,fv.g,fv.b), "ok")
            pop:Destroy()
        end)
    end)
    return yOff+rowGap
end

