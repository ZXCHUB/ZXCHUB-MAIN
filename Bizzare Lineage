local MISSION_HIGHLIGHT_COLOR = Color3.fromRGB(255, 0, 25)

local function FindNearestMissionBoard()
    local root = GetRoot()
    if not root then return nil end
    local map = workspace:FindFirstChild("Map")
    if not map then Toast("AutoMission","Map not found in workspace","err") return nil end
    local mb = map:FindFirstChild("Mission Boards")
    if not mb then Toast("AutoMission","Mission Boards folder not found","err") return nil end
    local pveFolder = mb:FindFirstChild("PvE")
    if not pveFolder then Toast("AutoMission","PvE folder not found","err") return nil end
    local children = pveFolder:GetChildren()
    if #children == 0 then Toast("AutoMission","PvE folder is empty","err") return nil end
    local root2 = GetRoot()
    if not root2 then return children[1] end
    local best, bestDist = nil, math.huge
    for _, model in ipairs(children) do
        local part = model:FindFirstChildOfClass("BasePart")
        if part then
            local dist = (part.Position - root2.Position).Magnitude
            if dist < bestDist then best = model; bestDist = dist end
        end
    end
    return best or children[1]
end

local function FindHighlightTargets()
    local results = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Highlight") then
            local fc = obj.FillColor
            local oc = obj.OutlineColor
            if math.abs(fc.R*255 - 255) < 5 and math.abs(fc.G*255) < 5 and math.abs(fc.B*255 - 25) < 10
            and math.abs(oc.R*255 - 255) < 5 and math.abs(oc.G*255) < 5 and math.abs(oc.B*255 - 25) < 10 then
                local model = obj.Parent
                if model and model:IsA("Model") then
                    local hum = model:FindFirstChildOfClass("Humanoid")
                    local hrp = model:FindFirstChild("HumanoidRootPart")
                    if hum and hum.Health > 0 and hrp then
                        table.insert(results, model)
                    end
                end
            end
        end
    end
    -- Sort by distance
    local root = GetRoot()
    if root then
        table.sort(results, function(a, b)
            local ha = a:FindFirstChild("HumanoidRootPart")
            local hb = b:FindFirstChild("HumanoidRootPart")
            local da = ha and (ha.Position - root.Position).Magnitude or math.huge
            local db = hb and (hb.Position - root.Position).Magnitude or math.huge
            return da < db
        end)
    end
    return results
end

local function GetNotificationFrame()
    local ok, holder = pcall(function()
        return lp.PlayerGui.Notifications.holder
    end)
    if not ok or not holder then return nil, nil end
    for _, child in ipairs(holder:GetChildren()) do
        local name = child.Name or ""
        if name == "Exterminate the targets." then
            return "exterminate", child
        end
        -- Match any "Deliver ... to <NPC>." regardless of what's being delivered
        local deliverTarget = name:match("^Deliver .+ to (.-)%.?$")
        if deliverTarget and deliverTarget ~= "" then
            return "deliver", deliverTarget
        end
    end
    return nil, nil
end

local function KillHighlightTargets()
    local targets = FindHighlightTargets()
    if #targets == 0 then return false end
    local toKill = math.min(5, #targets)
    for i = 1, toKill do
        local npc = targets[i]
        while Flags.AutoMissionBoard do
            if not npc or not npc.Parent then break end
            local hum = npc:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then break end
            GlideAboveNpc(npc)
            if tick() - QuestState.LastM1 >= 0.3 then
                QuestState.LastM1 = tick()
                DoM1()
            end
            if Flags.QuestUseSkills ~= false then DoSkillsAsync() end
            task.wait(0.1)
        end
        if not Flags.AutoMissionBoard then break end
    end
    return true
end

