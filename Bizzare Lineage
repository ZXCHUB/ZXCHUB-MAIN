function DoSkillsAsync()
    if SkillBusy then return end
    SkillBusy = true
    task.spawn(function()
        local ok, holder = pcall(function()
            return lp.PlayerGui["Stand Skills"].Holder
        end)
        if ok and holder then
            for _, entry in ipairs(SKILL_MAP) do
                if IsSkillReady(entry.frame) then
                    DoSkill(entry.key)
                    task.wait(0.2)
                end
            end
        end
        SkillBusy = false
    end)
end

function NormalizeLiveName(name)
    local s = tostring(name or "")
    s = s:gsub("^%p+", "")
    s = s:gsub("^%s+", ""):gsub("%s+$", "")
    s = s:gsub("(%l)(%u)", "%1 %2")
    s = s:gsub("(%a)(%d)", "%1 %2")
    s = s:gsub("(%d)(%a)", "%1 %2")
    s = s:gsub("%s+", " ")
    local last = s:match("(%S+)$")
    if last and #last >= 5 and #last <= 8 and last:match("^[A-Za-z]+$") and last:match("%u") and last:match("%l") then
        local prefix = s:sub(1, #s - #last)
        if prefix:match("%S") then s = prefix:gsub("%s+$", "") end
    end
    return s
end

function CanonNameKey(name)
    local s = string.lower(tostring(name or ""))
    s = s:gsub("[^%a%s]", " ")
    s = s:gsub("%s+", " ")
    s = s:gsub("^%s+", ""):gsub("%s+$", "")
    return s
end

function FirstNpcWord(name)
    local s = tostring(name or "")
    s = s:gsub("^%p+", "")
    s = s:gsub("^%s+", ""):gsub("%s+$", "")
    s = s:gsub("(%l)(%u)", "%1 %2")
    s = s:gsub("(%a)(%d)", "%1 %2")
    s = s:gsub("(%d)(%a)", "%1 %2")
    local first = s:match("^([A-Za-z]+)") or ""
    first = first:lower()
    if first == "" then
        local compact = CanonNameKey(name):gsub("%s+", "")
        first = compact:match("^([a-z]+)") or compact
    end
    if #first >= 6 then
        roots = {"delinquent","corrupt","thief","zombie","rogue","samurai","vampire","yakuza","mafia","cultist","boxer","thug","police","hamon","speedwagon","cyborg","prison","akira","okuyasu"}
        for _, root in ipairs(roots) do
            if first:sub(1, #root) == root then first = root; break end
        end
    end
    return first
end

function DisplayNpcWord(name)
    local first = FirstNpcWord(name)
    if first == "" then return "Unknown" end
    return first:sub(1,1):upper() .. first:sub(2)
end

function SameNpcType(a, b)
    local aa = FirstNpcWord(a)
    local bb = FirstNpcWord(b)
    return aa ~= "" and bb ~= "" and aa == bb
end

