-- Full raid loop: spawn → summon → attack → retry
function StartRaidLoop()
    if RaidState.IsRunning then return end
    RaidState.IsRunning = true
    task.spawn(function()
        -- Step 1: wait 5 seconds
        task.wait(5)

        -- Step 2: fire spawn remote
        pcall(function()
            local spawnEvent = game:GetService("ReplicatedStorage").requests.character.spawn
            spawnEvent:FireServer()
        end)
        -- Remove Main Menu GUI after spawn
        pcall(function()
            local mainMenu = lp.PlayerGui:FindFirstChild("Main Menu")
            if mainMenu then mainMenu:Destroy() end
        end)
        task.wait(2)

        -- ── Helper: get Live folder ──
        local function GetLiveFolder()
            return Workspace:FindFirstChild("Live")
        end

        -- ── Helper: attack one NPC until it dies or vanishes ──
        local function AttackNpc(npc)
            while Flags.AutoRaidEnabled and not IsInRaidPlace do
                if not npc or not npc.Parent then break end
                local hum = npc:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health <= 0 then break end
                GlideAboveNpc(npc)
                if tick() - RaidState.LastM1 >= 0.3 then
                    RaidState.LastM1 = tick()
                    DoM1()
                end
                if Flags.RaidUseSkills ~= false then DoSkillsAsync() end
                task.wait(0.1)
            end
            RaidState.CurrentTarget = nil
        end

        -- ── Helper: attack one crystal until it disappears from Live ──
        local function AttackCrystal(starName)
            while Flags.AutoRaidEnabled and not IsInRaidPlace do
                local live = GetLiveFolder()
                local star = live and live:FindFirstChild(starName, true)
                if not star then break end  -- disappeared → done
                RaidState.CurrentTarget = star
                GlideAboveCrystal(star)
                if tick() - RaidState.LastM1 >= 0.3 then
                    RaidState.LastM1 = tick()
                    DoM1()
                end
                if Flags.RaidUseSkills ~= false then DoSkillsAsync() end
                task.wait(0.1)
            end
            RaidState.CurrentTarget = nil
            task.wait(0.2)
        end

        -- ── Helper: attack normal NPCs until timer fires or no NPCs left ──
        -- Returns false if no NPC found (trigger retryraid), true otherwise
        local function RunNormalPhase(untilTime)
            while Flags.AutoRaidEnabled and not IsInRaidPlace do
                -- Check if time to switch to crystals
                if untilTime and tick() >= untilTime then return true end

                RaidState.LastTargetScan = 0
                local npc = FindNearestNonNetherstarNpc()
                if not npc then return false end  -- no NPCs → caller handles retry

                RaidState.CurrentTarget = npc
                while Flags.AutoRaidEnabled and not IsInRaidPlace do
                    if untilTime and tick() >= untilTime then
                        RaidState.CurrentTarget = nil
                        return true
                    end
                    if not npc or not npc.Parent then break end
                    local hum = npc:FindFirstChildOfClass("Humanoid")
                    if not hum or hum.Health <= 0 then break end
                    GlideAboveNpc(npc)
                    if tick() - RaidState.LastM1 >= 0.3 then
                        RaidState.LastM1 = tick()
                        DoM1()
                    end
                    if Flags.RaidUseSkills ~= false then DoSkillsAsync() end
                    task.wait(0.1)
                end
                RaidState.CurrentTarget = nil
                task.wait(0.1)
            end
            return true
        end

        -- ═══════════════════════════════════════════════════
        -- MAIN RAID SEQUENCE
        -- Phase 1 (60s): normal NPCs
        -- Phase 2:       Netherstar1 → 2 → 3 (until each disappears from Live)
        -- Phase 3:       normal NPCs indefinitely (retryraid if none left)
        -- ═══════════════════════════════════════════════════
        RaidState.PhaseStart = tick()
        RaidState.Phase = "normal_timed"

        -- Phase 1: attack NPCs for 60 seconds
        local crystalTime = tick() + 60
        RunNormalPhase(crystalTime)

        -- Phase 2: attack crystals in order
        if Flags.AutoRaidEnabled and not IsInRaidPlace then
            RaidState.Phase = "crystals"
            for _, starName in ipairs({"Netherstar1", "Netherstar2", "Netherstar3"}) do
                if not Flags.AutoRaidEnabled or IsInRaidPlace then break end
                AttackCrystal(starName)
            end
        end

        -- Phase 3: normal NPCs indefinitely
        RaidState.Phase = "normal"
        while Flags.AutoRaidEnabled and not IsInRaidPlace do
            local gotNpc = RunNormalPhase(nil)
            if not gotNpc then
                -- No NPCs left — fire retryraid
                if Flags.AutoRaidEnabled then
                    RaidState.WaitingRetry = true
                    local waitStart = tick()
                    while tick() - waitStart < 15 do
                        task.wait(1)
                        RaidState.CurrentTarget = nil
                        RaidState.LastTargetScan = 0
                        if FindNearestNonNetherstarNpc() then break end
                    end
                    if FindNearestNonNetherstarNpc() then
                        RaidState.WaitingRetry = false
                    else
                        pcall(function()
                            local retryEvent = game:GetService("ReplicatedStorage").requests.character.retryraid
                            retryEvent:FireServer()
                        end)
                        task.wait(1)
                        RaidState.WaitingRetry = false
                    end
                end
            end
        end

        RaidState.IsRunning = false
    end)
end

