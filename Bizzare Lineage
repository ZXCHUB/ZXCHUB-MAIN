    if tick() - FarmState.LastSummon < 2.25 then return end
    FarmState.LastSummon = tick()
    if not TryFireRemote(GetControllerRemote("SummonStand")) then
        if CanUseFallbackInput() then HoldKey(Enum.KeyCode.Tab, 0.08) end
    end
end

