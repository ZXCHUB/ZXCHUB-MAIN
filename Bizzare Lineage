            waiting=false
            Flags[flag]=inp.KeyCode.Name; bL.Text=inp.KeyCode.Name
            bindF.BackgroundColor3=C.bg3
            if callback then callback(inp.KeyCode) end
        end
    end)
    return yOff+rowGap
end

