    local talkTarget = text:match("^Talk to:%s*(.-)%s*$")
    if talkTarget and talkTarget ~= "" then
        return {type="talk", target=talkTarget}
    end

    if text:match("^Defeat%s+") then
        -- Capture name = letters/spaces between "Defeat " and first non-letter/non-space
        local defeatTarget = text:match("^Defeat%s+([%a ]+)%s*[^%a ]")
        if not defeatTarget then
            defeatTarget = text:match("^Defeat%s+([%a ]+)%s*$")
        end
        -- Grab numbers regardless of bracket type (「0/5」, [0/5], (0/5), etc.)
        local done, need = text:match("(%d+)/(%d+)")
        if defeatTarget and done and need then
            defeatTarget = defeatTarget:match("^%s*(.-)%s*$")
            return {type="defeat", target=defeatTarget, done=tonumber(done) or 0, need=tonumber(need) or 1}
        end
    end

    return nil
end

function IsQuestEnemy(model, targetWord)
    if not IsFarmNpc(model) then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    local dn = tostring(hum.DisplayName or ""):lower()
    return dn:find(targetWord:lower(), 1, true) ~= nil
end

function FindNearestQuestEnemy(targetWord)
    local folder = Workspace:FindFirstChild("Live")
    local root = GetRoot()
    if not folder or not root then return nil end
    local best, bestDist = nil, math.huge
    for _, model in ipairs(folder:GetChildren()) do
        if IsQuestEnemy(model, targetWord) then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then best = model; bestDist = dist end
            end
        end
    end
    return best
end

function GetStickyQuestTarget(targetWord)
    if IsQuestEnemy(QuestState.CurrentTarget, targetWord) then
        return QuestState.CurrentTarget
    end
    QuestState.CurrentTarget = FindNearestQuestEnemy(targetWord)
    return QuestState.CurrentTarget
end

