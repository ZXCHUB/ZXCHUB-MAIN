    local hum = model and model:FindFirstChildOfClass("Humanoid")
    local displayName = hum and hum.DisplayName or nil
    if displayName and tostring(displayName):gsub("%s+", "") ~= "" then
        return tostring(displayName)
    end
    return NormalizeLiveName(model and model.Name or "Unknown")
