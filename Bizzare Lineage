function BuildFarmTargetOptions()
    local folder = Workspace:FindFirstChild("Live")
    local groups, out = {}, {}
    local root = GetRoot()
    if not folder then return out end
    for _, model in ipairs(folder:GetChildren()) do
        if IsFarmNpc(model) then
            clean = GetFarmDisplayName(model)
            hrp = model:FindFirstChild("HumanoidRootPart")
            dist = (root and hrp) and (hrp.Position - root.Position).Magnitude or math.huge
            if clean ~= "" then
                matched = nil
                for _, group in ipairs(groups) do
                    if group.Name == clean then matched = group; break end
                end
                if matched then
                    matched.Dist = math.min(matched.Dist, dist)
                else
                    table.insert(groups, {Name = clean, Dist = dist})
                end
            end
        end
    end
    out = groups
    table.sort(out, function(a, b)
        if a.Dist == b.Dist then return a.Name < b.Name end
        return a.Dist < b.Dist
    end)
    names = {}
    for _, item in ipairs(out) do table.insert(names, item.Name) end
    return names
end

function IsTargetSelected(cleanName)
    local selected = FarmState.SelectedTargets
    if not selected or #selected == 0 then return true end
    return table.find(selected, cleanName) ~= nil
end

function FindNearestFarmNpc()
    local root = GetRoot()
    local folder = Workspace:FindFirstChild("Live")
    if not root or not folder then return nil end
    best, bestDist = nil, math.huge
    for _, model in ipairs(folder:GetChildren()) do
        if IsFarmNpc(model) then
            clean = GetFarmDisplayName(model)
            if IsTargetSelected(clean) then
                hrp = model:FindFirstChild("HumanoidRootPart")
                dist = (hrp.Position - root.Position).Magnitude
                if dist < bestDist then best = model; bestDist = dist end
            end
        end
    end
    return best
end

function IsValidFarmTarget(model)
    if not IsFarmNpc(model) then return false end
    clean = GetFarmDisplayName(model)
    return IsTargetSelected(clean)
end

function GetStickyFarmTarget()
    if IsValidFarmTarget(FarmState.CurrentTarget) then return FarmState.CurrentTarget end
    FarmState.CurrentTarget = FindNearestFarmNpc()
    return FarmState.CurrentTarget
end

