    if Flags.MultiJump and i.KeyCode == Enum.KeyCode.Space then
        hum = GetHumanoid()
        if hum and hum.FloorMaterial == Enum.Material.Air then
            hum:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

