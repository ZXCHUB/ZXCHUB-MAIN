    yAR = yAR + (isMobile and 36 or 32)

    function UpdateRaidStatus()
        if not Flags.AutoRaidEnabled then
            statusLbl.Text = "Status: Disabled"
            statusLbl.TextColor3 = C.txt2
        elseif RaidState.WaitingRetry then
            statusLbl.Text = "Status: All cleared — retrying..."
            statusLbl.TextColor3 = Color3.fromRGB(235,160,25)
        elseif RaidState.Phase == "crystals" then
            local tgt = RaidState.CurrentTarget
            local cname = tgt and tgt.Name or "..."
            statusLbl.Text = "Crystal phase — killing " .. cname
            statusLbl.TextColor3 = Color3.fromRGB(235,160,25)
        elseif RaidState.Phase == "normal_timed" then
            local secsLeft = math.max(0, math.ceil((RaidState.PhaseStart + 60) - tick()))
            statusLbl.Text = "Normal NPCs — crystals in " .. secsLeft .. "s"
            statusLbl.TextColor3 = C.acc
        elseif RaidState.CurrentTarget then
            local name = GetFarmDisplayName(RaidState.CurrentTarget)
            statusLbl.Text = "Attacking — " .. name
            statusLbl.TextColor3 = C.grn
        elseif RaidState.IsRunning then
            statusLbl.Text = "Status: Searching..."
            statusLbl.TextColor3 = C.acc
        else
            statusLbl.Text = "Status: Idle"
            statusLbl.TextColor3 = C.txt2
        end

        -- Boss HP + crystal debug
        pcall(function()
            -- Boss HP line
            local hud = lp.PlayerGui:FindFirstChild("MainHud")
            local holder = hud and hud:FindFirstChild("holder")
            local bossUi = holder and holder:FindFirstChild("BossUi")
            local healthLabel = bossUi and bossUi:FindFirstChild("health")
            if healthLabel then
                local txt = tostring(healthLabel.Text)
                if RaidState.BossHighHp then
                    bossDebugLbl.Text = "Boss: " .. txt .. " | Crystal ON"
                    bossDebugLbl.TextColor3 = C.grn
                else
                    bossDebugLbl.Text = "Boss: " .. txt .. " | Crystal OFF"
                    bossDebugLbl.TextColor3 = Color3.fromRGB(235,160,25)
                end
            else
                bossDebugLbl.Text = "BossUi: not found"
                bossDebugLbl.TextColor3 = C.txt2
            end

            -- Crystal detection debug: show what's found / not found
            local live = Workspace:FindFirstChild("Live")
            if not live then
                bossDebugLbl.Text = bossDebugLbl.Text .. " | Live: NO"
                return
            end
            local found = {}
            for _, name in ipairs({"Netherstar1","Netherstar2","Netherstar3"}) do
                if live:FindFirstChild(name, true) then
                    table.insert(found, name:gsub("Netherstar","NS"))
                end
            end
            if #found > 0 then
                bossDebugLbl.Text = bossDebugLbl.Text .. " | " .. table.concat(found,",")
                bossDebugLbl.TextColor3 = C.grn
            else
                -- Live exists but no Netherstars — list first 5 child names for debug
                local kids = {}
                for i, ch in ipairs(live:GetChildren()) do
                    if i > 5 then break end
                    table.insert(kids, ch.Name)
                end
                bossDebugLbl.Text = bossDebugLbl.Text .. " | Live kids: " .. table.concat(kids,",")
            end
        end)
    end

