function DoTalkToNPC(npcName)
    local root = GetRoot()
    if not root then return end

    local npcModel = FindNpcModel(npcName)

    -- If NPC not loaded, teleport to known coords first
    if not npcModel and NPC_LOCATIONS[npcName] then
        TeleportToPos(NPC_LOCATIONS[npcName])
        task.wait(1.5)
        npcModel = FindNpcModel(npcName)
    end

    -- Unknown NPC or still not found: cycle through all known locations
    if not npcModel then
        Toast("AutoQuest","Searching for "..npcName.."...","warn")
        local allCoords = {}
        for _, v in pairs(NPC_LOCATIONS) do table.insert(allCoords, v) end
        for _, pos in ipairs(allCoords) do
            if not Flags.AutoQuestEnabled then return end
            TeleportToPos(pos)
            task.wait(5)
            npcModel = FindNpcModel(npcName)
            if npcModel then break end
        end
    end

    if not npcModel then
        Toast("AutoQuest","NPC not found: "..npcName,"err")
        return
    end

    local npcHRP = npcModel:FindFirstChild("HumanoidRootPart")
    if not npcHRP then
        for _, v in ipairs(npcModel:GetDescendants()) do
            if v:IsA("BasePart") then npcHRP = v; break end
        end
    end
    if root and npcHRP then
        TeleportToPos(npcHRP.Position + Vector3.new(0, 0, -3))
        task.wait(0.4)
    end

    ActivatePromptOnModel(npcModel)
    task.wait(0.3)
    FireDialogue(npcModel)
    Toast("AutoQuest","Talk to: "..npcName,"ok")
end

