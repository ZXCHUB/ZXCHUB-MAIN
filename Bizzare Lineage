function BindFarmDeathWatcher(char)
    local hum = char and (char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid", 5))
    if not hum then return end
    hum.Died:Connect(function()
        if Flags.AutoFarmNearestNPC then
            FarmState.CurrentTarget = nil
            local currentRoot = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart
            if currentRoot then FarmState.LastDeathCFrame = currentRoot.CFrame end
        end
        if Flags.AutoRaidEnabled then
            RaidState.CurrentTarget = nil
            RaidState.LastTargetScan = 0
        end
    end)
end

if lp.Character then
    task.spawn(function() BindFarmDeathWatcher(lp.Character) end)
end

lp.CharacterAdded:Connect(function(char)
    ClearFlyObjects()
    BindFarmDeathWatcher(char)
    task.wait(2)
    if Flags.AutoFarmNearestNPC then
        local newRoot = char:FindFirstChild("HumanoidRootPart") or char.PrimaryPart or char:WaitForChild("HumanoidRootPart", 5)
        SummonStand()
        if newRoot and FarmState.LastDeathCFrame then
            pcall(function() newRoot.CFrame = FarmState.LastDeathCFrame end)
        end
    end
    -- Always summon stand 3 seconds after respawn
    task.spawn(function()
        task.wait(3)
        pcall(function()
            local ctrl = char:FindFirstChild("client_character_controller")
            if ctrl then
                local ss = ctrl:FindFirstChild("SummonStand")
                if ss then ss:FireServer() end
            end
        end)
    end)
    -- Restart raid loop on respawn if enabled and not in hub
    if Flags.AutoRaidEnabled and not IsInRaidPlace then
        RaidState.CurrentTarget = nil
        RaidState.WaitingRetry = false
        RaidState.LastTargetScan = 0
        task.wait(1)
        -- Only start if the old loop has naturally exited (prevents double coroutine)
        if not RaidState.IsRunning then
            StartRaidLoop()
        end
    end
end)

