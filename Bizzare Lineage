        if Flags.CollectAllArrows and not LootState.ArrowBusy and tick() - LootState.LastArrowScan >= 3 then
            LootState.LastArrowScan = tick()
            ProcessArrowBatch()
        end
        -- Auto open chests every 3 seconds
        if Flags.AutoOpenChests and Flags.AutoOpenChests_Types and #Flags.AutoOpenChests_Types > 0 then
            if tick() - ChestState.LastOpen >= 3 then
                ChestState.LastOpen = tick()
                selected = Flags.AutoOpenChests_Types
                pcall(function()
                    local ev = game:GetService("ReplicatedStorage").requests.character.use_item
                    for _, chestName in ipairs(CHEST_NAMES) do
                        if table.find(selected, chestName) then
                            pcall(function() ev:FireServer(chestName, { UseAll = true }) end)
                        end
                    end
                end)
            end
        end
        -- Auto use arrows: fire every 1.5s until desired stand+personality matched
        if Flags.AutoUseArrows and ArrowState.Running then
            if IsDesiredStand() then
                -- Match found — stop
                ArrowState.Running = false
                Flags.AutoUseArrows = false
                if Setters["AutoUseArrows"] then Setters["AutoUseArrows"](false) end
                Toast("Arrows","Stand matched! Stopping.","ok")
            elseif tick() - ArrowState.LastArrowUse >= 1.5 then
                ArrowState.LastArrowUse = tick()
                UseArrow()
            end
        end
        PlayerStep()
        AutoFarmStep()
    end
end)

