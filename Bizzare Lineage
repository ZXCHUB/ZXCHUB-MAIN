function GetArrowPrompt(obj)
    if not obj then return nil end
    return obj:FindFirstChildWhichIsA("ProximityPrompt", true)
end

function LookCameraAt(pos)
    Camera = Workspace.CurrentCamera or Camera
    if Camera then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, pos)
    end
end

function HoldKey(keyCode, seconds)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
        task.wait(seconds or 0.5)
        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
    end)
end

function ActivateArrowPrompt(prompt, arrow)
    if not prompt then return false end
    prompt.HoldDuration = 0.1
    if fireproximityprompt then
        ok = pcall(function() fireproximityprompt(prompt) end)
        if ok then return true end
    end
    LookCameraAt(arrow.Position)
    HoldKey(Enum.KeyCode.E, 0.5)
    return true
end

function CollectArrow(arrow)
    if LootState.ArrowBusy or not arrow or not arrow.Parent then return end
    root = GetRoot()
    if not root then return end
    prompt = GetArrowPrompt(arrow)
    LootState.ArrowBusy = true
    pcall(function() root.CFrame = CFrame.new(arrow.Position + Vector3.new(0, 3, 0)) end)
    task.wait(0.15)
    if ActivateArrowPrompt(prompt, arrow) then
        LootState.Seen[arrow] = tick()
    end
    task.wait(0.25)
    LootState.ArrowBusy = false
end

function FindAllStandArrows()
    local root = GetRoot()
    if not root then return {} end
    arrows = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("MeshPart") and obj.Name == "Stand Arrow" and obj.Parent then
            lastSeen = LootState.Seen[obj]
            if not lastSeen or tick() - lastSeen > 2 then
                table.insert(arrows, obj)
            end
        end
    end
    table.sort(arrows, function(a, b)
        return (a.Position - root.Position).Magnitude < (b.Position - root.Position).Magnitude
    end)
    return arrows
end

function FindNearestStandArrow()
    return FindAllStandArrows()[1]
end

function ProcessArrowBatch()
    if LootState.ArrowBusy then return end
    root = GetRoot()
    if not root then return end
    arrows = FindAllStandArrows()
    if #arrows == 0 then return end
    LootState.HomeCFrame = root.CFrame
    LootState.ArrowBusy = true
    task.spawn(function()
        for _, arrow in ipairs(arrows) do
            if Flags.CollectAllArrows and arrow and arrow.Parent then
                LootState.ArrowBusy = false
                CollectArrow(arrow)
                task.wait(0.2)
                LootState.ArrowBusy = true
            end
        end
        backRoot = GetRoot()
        if backRoot and LootState.HomeCFrame then
            pcall(function() backRoot.CFrame = LootState.HomeCFrame end)
        end
        LootState.HomeCFrame = nil
        LootState.ArrowBusy = false
    end)
end

