-- Get position from any object inside a model — tries everything available
function GetCrystalPosition(model)
    if not model then return nil end
    -- 1. HumanoidRootPart (recursive)
    local hrp = model:FindFirstChild("HumanoidRootPart", true)
    if hrp and hrp:IsA("BasePart") then return hrp.Position end
    -- 2. PrimaryPart
    if model.PrimaryPart then return model.PrimaryPart.Position end
    -- 3. Any BasePart anywhere inside (recursive)
    local bp = model:FindFirstChildWhichIsA("BasePart", true)
    if bp then return bp.Position end
    -- 4. GetPivot() — works if the model has a set pivot
    local ok, pivot = pcall(function() return model:GetPivot() end)
    if ok and pivot then return pivot.Position end
    -- 5. GetBoundingBox() — gives center of the model's bounding box
    local ok2, cf = pcall(function() return model:GetBoundingBox() end)
    if ok2 and cf then return cf.Position end
    return nil
end

-- Teleport player above a crystal — if no position found, skip move but still attack
