    local ok, gradient = pcall(function()
        return lp.PlayerGui["Stand Skills"].Holder[frameName].Cooldown.UIGradient
    end)
    -- if path doesn't exist assume ready; only skip if gradient exists and shows cooldown
    if not ok or not gradient then return true end
    return gradient.Offset.X >= 1
