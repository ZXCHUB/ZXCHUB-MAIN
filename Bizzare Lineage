function StartMissionBoardLoop()
    if MissionState.IsRunning then return end
    MissionState.IsRunning = true
    task.spawn(function()
        while Flags.AutoMissionBoard do
            -- Find nearest board
            local board = FindNearestMissionBoard()
            if not board then task.wait(5); continue end
            MissionState.BoardTarget = board

            -- Find any BasePart in the board (search all descendants)
            local boardPart = nil
            for _, d in ipairs(board:GetDescendants()) do
                if d:IsA("BasePart") then boardPart = d; break end
            end
            if not boardPart and board:IsA("BasePart") then boardPart = board end

            -- Teleport to board
            if boardPart then
                Toast("AutoMission","Teleporting to board","ok")
                local root = GetRoot()
                if root then
                    -- Step 1: land within ~8 studs so ProximityPrompt appears on screen
                    pcall(function() root.CFrame = CFrame.new(boardPart.Position + Vector3.new(0,0,-8)) end)
                    task.wait(0.5)
                    -- Step 2: move right up to the board to ensure activation range
                    for _ = 1, 3 do
                        pcall(function() root.CFrame = CFrame.new(boardPart.Position + Vector3.new(0,0,-2)) end)
                        task.wait(0.1)
                    end
                end
                task.wait(0.5)
            end

            -- Activate board ProximityPrompt
            ActivatePromptOnModel(board)
            Toast("AutoMission","Board activated, waiting for mission...","ok")
            task.wait(0.3)

            -- Poll Notifications.holder for up to 7 seconds
            local missionType, missionData = nil, nil
            for _ = 1, 35 do
                if not Flags.AutoMissionBoard then break end
                missionType, missionData = GetNotificationFrame()
                if missionType then break end
                task.wait(0.2)
            end
            if not Flags.AutoMissionBoard then break end

            local missionStart = tick()
            local function TimedOut() return tick() - missionStart > 60 end

            -- ── EXTERMINATE ──────────────────────────────────────
            if missionType == "exterminate" then
                Toast("AutoMission","Exterminate! Waiting for targets...","ok")
                -- Wait up to 6 seconds for targets to spawn
                local targets = {}
                for _ = 1, 30 do
                    targets = FindHighlightTargets()
                    if #targets > 0 then break end
                    task.wait(0.2)
                end
                if #targets == 0 then
                    Toast("AutoMission","No targets found, resetting...","warn")
                    MissionResetCharacter()
                    continue
                end
                -- Kill ALL highlighted NPCs, re-scanning after each kill
                while Flags.AutoMissionBoard do
                    if TimedOut() then break end
                    targets = FindHighlightTargets()
                    if #targets == 0 then break end
                    local npc = targets[1]
                    while Flags.AutoMissionBoard do
                        if TimedOut() then break end
                        if not npc or not npc.Parent then break end
                        local hum = npc:FindFirstChildOfClass("Humanoid")
                        if not hum or hum.Health <= 0 then break end
                        GlideAboveNpc(npc)
                        if tick() - QuestState.LastM1 >= 0.3 then
                            QuestState.LastM1 = tick()
                            DoM1()
                        end
                        if Flags.QuestUseSkills ~= false then DoSkillsAsync() end
                        task.wait(0.1)
                    end
                end
                if TimedOut() then
                    Toast("AutoMission","Mission timed out, resetting...","warn")
                    MissionResetCharacter(); continue
                end
                Toast("AutoMission","Targets done, waiting 5s...","ok")
                task.wait(5)

            -- ── DELIVER BRIEFCASE ────────────────────────────────
            elseif missionType == "deliver" then
                local npcName = missionData
                Toast("AutoMission","Deliver to: "..tostring(npcName),"ok")

                -- Step 1: try to find NPC where we are now
                local npcModel = MissionFindNpc(npcName)

                -- Step 2: if known coords, teleport there first
                if not npcModel and NPC_LOCATIONS[npcName] then
                    Toast("AutoMission","Teleporting to "..npcName.." coords","ok")
                    TeleportToPos(NPC_LOCATIONS[npcName])
                    task.wait(3)
                    npcModel = MissionFindNpc(npcName)
                end

                -- Step 3: cycle ALL coords only if truly not found
                if not npcModel then
                    Toast("AutoMission","Searching for "..tostring(npcName),"warn")
                    for _, pos in pairs(NPC_LOCATIONS) do
                        if not Flags.AutoMissionBoard then break end
                        if TimedOut() then break end
                        TeleportToPos(pos)
                        task.wait(5)
                        npcModel = MissionFindNpc(npcName)
                        if npcModel then break end
                    end
                end

                if TimedOut() then
                    Toast("AutoMission","Mission timed out, resetting...","warn")
                    MissionResetCharacter(); continue
                end
                if not npcModel then
                    Toast("AutoMission","NPC not found: "..tostring(npcName),"err")
                    task.wait(5); continue
                end

                -- Teleport to NPC
                local hrp = npcModel:FindFirstChild("HumanoidRootPart")
                if not hrp then
                    for _, d in ipairs(npcModel:GetDescendants()) do
                        if d:IsA("BasePart") then hrp = d; break end
                    end
                end
                if hrp then
                    TeleportToPos(hrp.Position + Vector3.new(0,0,-3))
                    task.wait(1)
                end
                ActivatePromptOnModel(npcModel)
                task.wait(0.3)
                -- Fire dialogue 20 times fast
                local ok2, Event = pcall(function()
                    return game:GetService("ReplicatedStorage").requests.character.dialogue
                end)
                if ok2 and Event then
                    for _ = 1, 20 do
                        pcall(function() Event:FireServer(npcModel, "Continue") end)
                        task.wait(0.05)
                    end
                end
                Toast("AutoMission","Deliver done, waiting 5s...","ok")
                task.wait(5)

            else
                Toast("AutoMission","No mission detected, resetting...","warn")
                MissionResetCharacter()
            end
        end
        MissionState.IsRunning = false
    end)
end

function StartQuestLoop()
    if QuestState.IsRunning then return end
    QuestState.IsRunning = true
    task.spawn(function()
        while Flags.AutoQuestEnabled do
            local text = GetQuestText()
            if not text then task.wait(1); continue end

            local quest = ParseQuest(text)
            if not quest then task.wait(1); continue end

            if quest.type == "talk" then
                DoTalkToNPC(quest.target)
                task.wait(3)

            elseif quest.type == "defeat" then
                local npc = GetStickyQuestTarget(quest.target)
                if npc then
                    while Flags.AutoQuestEnabled do
                        npc = GetStickyQuestTarget(quest.target)
                        if not npc then break end
                        local hum = npc:FindFirstChildOfClass("Humanoid")
                        if not hum or hum.Health <= 0 then
                            QuestState.CurrentTarget = nil
                            task.wait(0.2)
                            break
                        end
                        GlideAboveNpc(npc)
                        if tick() - QuestState.LastM1 >= 0.3 then
                            QuestState.LastM1 = tick()
                            DoM1()
                        end
                        if Flags.QuestUseSkills ~= false then DoSkillsAsync() end
                        task.wait(0.1)
                    end
                else
                    task.wait(1)
                end
            else
                task.wait(1)
            end
        end
        QuestState.IsRunning = false
    end)
end

function ToggleFlyState(forceValue)
    if type(forceValue) == "boolean" then
        PlayerState.FlyEnabled = forceValue
    else
        PlayerState.FlyEnabled = not PlayerState.FlyEnabled
    end
    Flags.FlyToggle = PlayerState.FlyEnabled
    if not PlayerState.FlyEnabled then
        root = GetRoot()
        if root then root.AssemblyLinearVelocity = Vector3.zero end
        ClearFlyObjects()
    end
    Toast("Player", PlayerState.FlyEnabled and "Fly enabled" or "Fly disabled", PlayerState.FlyEnabled and "ok" or "warn")
end

function PlayerStep()
    local hum = GetHumanoid()
    local root = GetRoot()
    if hum and not Flags.AutoFarmNearestNPC and not Flags.AutoRaidEnabled then
        hum.AutoRotate = true
        if hum:GetState() == Enum.HumanoidStateType.Physics then
            hum:ChangeState(Enum.HumanoidStateType.Running)
        end
    end
    if hum and Flags.SpeedEnabled then
        hum.WalkSpeed = tonumber(Flags.SpeedValue) or 16
    end
    if PlayerState.FlyEnabled and root then
        cam = Workspace.CurrentCamera or Camera
        if cam then
            flySpeed = tonumber(Flags.FlySpeed) or 300
            move = Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then move += cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S) then move -= cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then move -= cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D) then move += cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then move += Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then move -= Vector3.new(0,1,0) end
            hum.AutoRotate = false
            hum.PlatformStand = false
            hum:ChangeState(Enum.HumanoidStateType.Freefall)
            flatLook = Vector3.new(cam.CFrame.LookVector.X, 0, cam.CFrame.LookVector.Z)
            if flatLook.Magnitude > 0.05 then
                root.CFrame = CFrame.lookAt(root.Position, root.Position + flatLook.Unit)
            end
            if move.Magnitude > 0 then
                root.AssemblyLinearVelocity = move.Unit * flySpeed
            else
                root.AssemblyLinearVelocity = Vector3.zero
            end
        end
    else
        ClearFlyObjects()
    end
end

