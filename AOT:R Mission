-- ── AUTOFARM ───────────────────────────────────────────
local isAttacking = false
local FARM_EDGE = 5

-- Expand each titan's Nape hitbox so Register hits land reliably
local function ExpandHitboxes()
    local titansFolder = workspace:FindFirstChild("Titans")
    if not titansFolder then return end
    for _, titan in ipairs(titansFolder:GetChildren()) do
        local hum = titan:FindFirstChild("Humanoid")
        if hum and hum.Health > 0 then
            local hitboxes = titan:FindFirstChild("Hitboxes")
            local nape = hitboxes and hitboxes:FindFirstChild("Hit") and hitboxes.Hit:FindFirstChild("Nape")
            if nape and nape:IsA("BasePart") then
                nape.Size = Vector3.new(50, 50, 50)
                nape.CanCollide = false
            end
        end
    end
end

-- Find the Nape of the nearest alive titan
local function GetNearestNape()
    local char = lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local titansFolder = workspace:FindFirstChild("Titans")
    if not titansFolder then return nil end
    local bestDist, bestNape = math.huge, nil
    for _, titan in ipairs(titansFolder:GetChildren()) do
        local hum      = titan:FindFirstChild("Humanoid")
        local hitboxes = titan:FindFirstChild("Hitboxes")
        local nape     = hitboxes and hitboxes:FindFirstChild("Hit") and hitboxes.Hit:FindFirstChild("Nape")
        if hum and hum.Health > 0 and nape then
            local d = (nape.Position - hrp.Position).Magnitude
            if d < bestDist then bestDist = d; bestNape = nape end
        end
    end
    return bestNape
end

-- Send Slash start → Register hit on Nape → Slash end
local function GetRefillBox()
    -- Try known paths first
    local paths = {
        {"Unclimbable", "Reloads"},
        {"Climbable", "_Walls", "Gate", "GasTanks"},
        {"Climbable", "Reloads"},
        {"Unclimbable", "GasTanks"},
    }
    for _, path in ipairs(paths) do
        local node = workspace
        for _, part in ipairs(path) do
            node = node:FindFirstChild(part)
            if not node then break end
        end
        if node then
            -- node is the container: look for a child that has a "Refill" part
            for _, child in ipairs(node:GetChildren()) do
                if child:FindFirstChild("Refill") then return child end
            end
            -- or node itself has Refill
            if node:FindFirstChild("Refill") then return node end
        end
    end
    -- Fallback: deep search the whole workspace for any BasePart named "Refill"
    local refill = workspace:FindFirstChild("Refill", true)
    if refill then return refill.Parent end
    return nil
end

local attackCount = 0

local function DoBladeEquip()
    task.spawn(function()
        pcall(function() GetGET():InvokeServer("Blades", "Reload") end)
    end)
end

local function DoBladeRefill()
    local box = GetRefillBox()
    if box then
        local refillPart = box:FindFirstChild("Refill") or box
        task.spawn(function()
            pcall(function() GetPOST():FireServer("Attacks", "Reload", refillPart) end)
        end)
        Toast("Refill", "Sent: "..refillPart:GetFullName(), "ok")
    else
        Toast("Refill", "Box not found in workspace", "err")
    end
end

local function DoAttack(nape)
    if isAttacking then return end
    isAttacking = true
    task.spawn(function()
        pcall(function() GetPOST():FireServer("Attacks", "Slash", true) end)
        task.wait(0.1)
        pcall(function() GetPOST():FireServer("Hitboxes", "Register", nape, 500, 0.15) end)
        task.wait(0.2)
        pcall(function() GetPOST():FireServer("Attacks", "Slash", false) end)
        task.wait(0.1)
        attackCount = attackCount + 1
        if attackCount % 24 == 0 then
            DoBladeRefill()
        elseif attackCount % 6 == 0 then
            DoBladeEquip()
        end
        isAttacking = false
    end)
end

-- Noclip: disable collision on character parts while farming
RunService.Stepped:Connect(function()
    if not Flags.AutoFarm then return end
