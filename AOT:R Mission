end)

-- Main farm: runs every frame via Heartbeat
RunService.Heartbeat:Connect(function(dt)
    if not Flags.AutoFarm or farmMethod ~= "Blades" then return end

    ExpandHitboxes()

    local char = lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Kill gravity / keep character airborne
    hrp.AssemblyLinearVelocity = Vector3.zero

    local nape = GetNearestNape()
    if not nape then return end

    -- Hover above nape, slightly behind its look direction
    local floatH   = Flags.FloatHeight or 100
    local targetPos = nape.Position
        + Vector3.new(0, floatH + FARM_EDGE, 0)
        + nape.CFrame.LookVector * -5

    local dist  = (targetPos - hrp.Position).Magnitude
    local speed = Flags.FarmSpeed or 100

    if dist > 2 then
        -- Glide toward hover point, face the nape
        local step   = math.min(speed * dt, dist)
        local newPos = hrp.Position + (targetPos - hrp.Position).Unit * step
        hrp.CFrame   = CFrame.lookAt(newPos, nape.Position)
    else
        -- Arrived — stay in place and spam attack
        hrp.CFrame = CFrame.lookAt(hrp.Position, nape.Position)
        DoAttack(nape)
    end
end)

