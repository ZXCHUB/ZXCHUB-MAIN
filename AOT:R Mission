        -- RGB slider builder
        local connections = {}
        local function AddRGBSlider(colorKey, labelTxt, fillCol, yPos)
            local slH  = isMobile and 46 or 40
            local base = Instance.new("Frame", pop)
            base.Size  = UDim2.new(1,-16,0,slH)
