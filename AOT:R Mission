            local baseStroke = Instance.new("UIStroke", base)
            baseStroke.Color = C.brd; baseStroke.Thickness = 1

            -- Key label
            local kLbl = Instance.new("TextLabel", base)
            kLbl.Size = UDim2.new(0,16, 0, isMobile and 18 or 16)
            kLbl.Position = UDim2.new(0,8, 0, isMobile and 5 or 4)
            kLbl.BackgroundTransparency = 1
            kLbl.Text = labelTxt
            kLbl.TextColor3 = C.txt2
            kLbl.Font = Enum.Font.GothamBold
            kLbl.TextSize = isMobile and 11 or 10
            kLbl.ZIndex = 212

            -- Value label
            local vLbl = Instance.new("TextLabel", base)
            vLbl.Size = UDim2.new(0,32, 0, isMobile and 18 or 16)
            vLbl.Position = UDim2.new(1,-38, 0, isMobile and 5 or 4)
            vLbl.BackgroundTransparency = 1
            vLbl.TextColor3 = C.txt2
            vLbl.Font = Enum.Font.GothamMedium
            vLbl.TextSize = isMobile and 10 or 10
            vLbl.TextXAlignment = Enum.TextXAlignment.Right
            vLbl.ZIndex = 212

            -- Track
            local trkY = isMobile and 28 or 24
            local track = Instance.new("Frame", base)
            track.Size = UDim2.new(1,-16,0,6)
            track.Position = UDim2.new(0,8,0,trkY)
            track.BackgroundColor3 = C.bg4
            track.BorderSizePixel  = 0
            track.ZIndex = 212
            Instance.new("UICorner", track).CornerRadius = UDim.new(0,3)

            local fill = Instance.new("Frame", track)
            fill.Size = UDim2.new(0,0,1,0)
            fill.BackgroundColor3 = fillCol
            fill.BorderSizePixel  = 0
            fill.ZIndex = 213
            Instance.new("UICorner", fill).CornerRadius = UDim.new(0,3)

            local tSz = isMobile and 14 or 12
            local thumb = Instance.new("Frame", track)
            thumb.Size = UDim2.new(0,tSz,0,tSz)
            thumb.BackgroundColor3 = C.white
            thumb.BorderSizePixel  = 0
            thumb.ZIndex = 214
            Instance.new("UICorner", thumb).CornerRadius = UDim.new(0,tSz/2)
            local tStroke = Instance.new("UIStroke", thumb)
            tStroke.Color = C.brd2; tStroke.Thickness = 1

            local function SetV(v)
                local iv  = math.clamp(math.floor(v+0.5), 0, 255)
                Flags[flag][colorKey] = iv
                local pct = iv/255
                fill.Size  = UDim2.new(pct,0,1,0)
                thumb.Position = UDim2.new(pct,-tSz/2, 0.5,-tSz/2)
                vLbl.Text  = tostring(iv)
                RefreshAll()
            end
            local function PosToVal(ax)
                return 255 * math.clamp(
                    (ax - track.AbsolutePosition.X) / math.max(track.AbsoluteSize.X, 1), 0, 1)
            end
            SetV(Flags[flag][colorKey])

            local dragging = false
            track.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1
                or i.UserInputType==Enum.UserInputType.Touch then
                    dragging = true; SetV(PosToVal(i.Position.X))
                end
            end)
            thumb.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1
                or i.UserInputType==Enum.UserInputType.Touch then
                    dragging = true
                end
            end)
            table.insert(connections, UIS.InputChanged:Connect(function(i)
                if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement
                or i.UserInputType==Enum.UserInputType.Touch) then
                    SetV(PosToVal(i.Position.X))
                end
            end))
            table.insert(connections, UIS.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1
                or i.UserInputType==Enum.UserInputType.Touch then
                    dragging = false
                end
            end))
        end

        local gap = isMobile and 54 or 48
        local startY = hH + prevH + 14
        AddRGBSlider("r", "R", Color3.fromRGB(220,60,60),  startY)
        AddRGBSlider("g", "G", Color3.fromRGB(55,200,80),  startY + gap)
        AddRGBSlider("b", "B", Color3.fromRGB(60,120,240), startY + gap*2)

        -- Disconnect UIS listeners when popup is destroyed
        pop.AncestryChanged:Connect(function()
            if not pop.Parent then
                for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
            end
        end)
    end)

    return yOff+rowGap
end

