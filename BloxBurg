    end
local function FindOreFolder()
    if CachedOreFolder and CachedOreFolder.Parent then return CachedOreFolder end
    CachedOreFolder=nil
    local g=workspace:FindFirstChild("_game")
    if not g then
        if folderLbl then folderLbl.Text="Folder: _game not found!"; folderLbl.TextColor3=C.acc end
        return nil
    end
    local folder=g:FindFirstChild("Folder")
    if folder then
