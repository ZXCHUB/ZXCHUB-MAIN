local function Toast(title,msg,kind)
    local col=kind=="err" and C.acc or kind=="ok" and C.grn or kind=="warn" and Color3.fromRGB(235,160,25) or C.txt2
    local tW=isMobile and 210 or 240
    local t=Frame(GUI,UDim2.new(0,tW,0,50),UDim2.new(1,20,0,20),C.bg0,6)
    t.ClipsDescendants=true; Stroke(t,C.brd2,1)
