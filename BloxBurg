local function BuildFisherTab()
    local P=MakePage(); local S=MakeScroll(P)
    local Col=Frame(S,UDim2.new(1,-16,0,1),UDim2.new(0,8,0,0),C.bg0)
    Col.BackgroundTransparency=1; Col.AutomaticSize=Enum.AutomaticSize.Y

    local FishRemote=nil; local CastPayload=nil; local ReelPayload=nil
    local FishPhase="idle"; local AutofarmEnabled=false; local FishLoopThread=nil
    local statusLbl,statusSub,castLbl,reelLbl

    local function SetStatus(m,s,c)
        if statusLbl then statusLbl.Text="Status: "..m; statusLbl.TextColor3=c or C.txt2 end
        if statusSub then statusSub.Text=s or "" end
    end
    local function StopLoop()
        if FishLoopThread then task.cancel(FishLoopThread); FishLoopThread=nil end
    end
    local function StartLoop()
        StopLoop()
        FishLoopThread=task.spawn(function()
            while AutofarmEnabled and FishPhase=="working" do
                local ok1=pcall(function() FishRemote:FireServer(CastPayload) end)
                if not ok1 then FishRemote=nil; CastPayload=nil; ReelPayload=nil; FishPhase="wait_cast"; break end
                task.wait(2); if not AutofarmEnabled or FishPhase~="working" then break end
                local char=lp.Character
                local rod=char and char:FindFirstChild("Fishing Rod")
                local bob=rod and rod:FindFirstChild("Bobber")
                if bob then
                    local lastCF=bob.CFrame; local t0=tick()
                    while AutofarmEnabled and FishPhase=="working" do
                        task.wait(0.05); if bob.CFrame~=lastCF then break end
                        if tick()-t0>90 then break end
                    end
                else task.wait(5) end
                if not AutofarmEnabled or FishPhase~="working" then break end
                pcall(function() FishRemote:FireServer(ReelPayload) end); task.wait(1)
            end
        end)
    end
    local hookSetup=false
    local function SetupHook()
        if hookSetup then return end; hookSetup=true
        if not hookmetamethod then return end
        local old; old=hookmetamethod(game,"__namecall",function(self,...)
            local method=getnamecallmethod(); local args={...}
            if method=="FireServer" and AutofarmEnabled then
                local payload=args[1]
                if type(payload)=="table" then
                    if FishPhase=="wait_cast" then
                        if payload.State~=nil and payload.Pos~=nil and typeof(payload.Pos)=="Vector3" then
                            FishRemote=self; CastPayload={State=payload.State,Pos=payload.Pos}
                            FishPhase="wait_reel"
                        end
                    elseif FishPhase=="wait_reel" then
                        if self==FishRemote and payload.State~=nil and payload.Time~=nil and type(payload.Time)=="number" then
                            ReelPayload={State=payload.State,Time=payload.Time}
                            FishPhase="working"
                        end
                    end
                end
            end
            return old(self,...)
        end)
    end
    local prevPhase=""
    RunService.Heartbeat:Connect(function()
        if FishPhase~=prevPhase then
            prevPhase=FishPhase
            if FishPhase=="idle" then SetStatus("Idle","",C.txt2) end
            if FishPhase=="wait_cast" then SetStatus("Waiting...","Cast your fishing rod manually!",Color3.fromRGB(235,160,25)) end
            if FishPhase=="wait_reel" then
                SetStatus("Waiting...","Now wait and reel in the first fish!",Color3.fromRGB(235,160,25))
                if castLbl then castLbl.Text="Cast remote: OK"; castLbl.TextColor3=C.grn end
            end
            if FishPhase=="working" then
                SetStatus("Working!","Auto-fishing active",C.grn)
                if reelLbl then reelLbl.Text="Reel remote: OK"; reelLbl.TextColor3=C.grn end
                StartLoop()
            end
        end
        if not AutofarmEnabled and FishPhase~="idle" then FishPhase="idle" end
    end)
    local y=8
    y=MakeSection(Col,"FisherMan",y)
    y=MakeToggle(Col,"Enable FisherMan",y,"FishEnabled",function(v)
        AutofarmEnabled=v
        if v then
            SetupHook(); FishRemote=nil; CastPayload=nil; ReelPayload=nil
            FishPhase="wait_cast"; Toast("Fisherman","Cast your fishing rod!","warn")
        else StopLoop(); FishPhase="idle"; SetStatus("Idle","",C.txt2); Toast("Fisherman","Stopped","err") end
    end)
    y=MakeSection(Col,"Status",y)
    statusLbl,statusSub,y=MakeSBox(Col,y)
    castLbl,y=MakeIBox(Col,"Cast remote: Not detected",y)
    reelLbl,y=MakeIBox(Col,"Reel remote: Not detected",y)
    y=y+4
    y=MakeActionBtn(Col,"Reset FisherMan",y,function()
        if AutofarmEnabled then Toast("Warning","Stop first!","err"); return end
        FishRemote=nil; CastPayload=nil; ReelPayload=nil; FishPhase="idle"
        if castLbl then castLbl.Text="Cast remote: Not detected"; castLbl.TextColor3=C.txt2 end
        if reelLbl then reelLbl.Text="Reel remote: Not detected"; reelLbl.TextColor3=C.txt2 end
        SetStatus("Idle","",C.txt2); Toast("Reset","Done","ok")
    end)
    y=y+8; MakeHelpBox(Col,y)
end

