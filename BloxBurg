-- TAB 1: WOODCUTTER (1:1 из Woodcutter.txt)
-- ════════════════════════════════════════════════════════
local function BuildWoodTab()
    local P=MakePage(); local S=MakeScroll(P)
    local Col=Frame(S,UDim2.new(1,-16,0,1),UDim2.new(0,8,0,0),C.bg0)
    Col.BackgroundTransparency=1; Col.AutomaticSize=Enum.AutomaticSize.Y

    local WoodRemote=nil; local WoodPhase="idle"
    local AutofarmEnabled=false; local WoodLoopThread=nil
    local ShiftEarnings=nil; local LastEarnings=0; local EarningsChanged=false
    local RecentTrees={}; local WorkingTrees={}
    local HISTORY_SIZE=5; local WORKING_COUNT=7; local MOVE_THRESHOLD=10
    local WAIT_POS=Vector3.new(3117.38,140.16,-1830.62)
    local IGNORE_ZERO_DURATION=60
    local statusLbl,statusSub,remoteLbl,treeLbl,earningsLbl,scanLbl

    local function SetStatus(m,s,c)
        if statusLbl then statusLbl.Text="Status: "..m; statusLbl.TextColor3=c or C.txt2 end
        if statusSub then statusSub.Text=s or "" end
    end

    -- 1:1 из Woodcutter.txt
    local function GetSpruceFolder()
        local env=workspace:FindFirstChild("Environment"); if not env then return nil end
        local fol=env:FindFirstChild("Foliage"); if not fol then return nil end
        local trees=fol:FindFirstChild("Trees"); if not trees then return nil end
        return trees:FindFirstChild("Spruce Tree")
    end

    local function GetBodyPart(treeModel)
        if not treeModel or not treeModel.Parent then return nil end
        local body=treeModel:FindFirstChild("Body"); if not body then return nil end
        if body:IsA("BasePart") then return body end
        if body:IsA("Model") then
            return body.PrimaryPart or body:FindFirstChildOfClass("BasePart")
        end
        return nil
    end

    local function ScanTrees()
        WorkingTrees={}
        local sf=GetSpruceFolder()
        if not sf then
            if scanLbl then scanLbl.Text="No folder!"; scanLbl.TextColor3=C.acc end; return
        end
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then
            if scanLbl then scanLbl.Text="No character!"; scanLbl.TextColor3=C.acc end; return
        end
        local all={}
        for _,tree in ipairs(sf:GetChildren()) do
            local bp=GetBodyPart(tree)
            if bp then
                local dx=hrp.Position.X-bp.Position.X
                local dz=hrp.Position.Z-bp.Position.Z
                local dist=math.sqrt(dx*dx+dz*dz)
                table.insert(all,{tree=tree,basePos=bp.Position,name=tree.Name,dist=dist})
            end
        end
        table.sort(all,function(a,b) return a.dist<b.dist end)
        for i,e in ipairs(all) do
            if i>WORKING_COUNT then break end
            table.insert(WorkingTrees,{tree=e.tree,basePos=e.basePos,name=e.name})
        end
        if scanLbl then
            scanLbl.Text=#WorkingTrees.." trees ready"
            scanLbl.TextColor3=C.grn
        end
    end

    local function IsTreeAlive(entry)
        if not entry.tree or not entry.tree.Parent then return false end
        local bp=GetBodyPart(entry.tree); if not bp then return false end
        local diff=(bp.Position-entry.basePos).Magnitude
        if diff>=MOVE_THRESHOLD then
            if diff<MOVE_THRESHOLD+5 then entry.basePos=bp.Position; return true end
            return false
        end
        return true
    end

    local function IsInHistory(name)
        for _,n in ipairs(RecentTrees) do if n==name then return true end end; return false
    end
    local function AddToHistory(name)
        table.insert(RecentTrees,name)
        while #RecentTrees>HISTORY_SIZE do table.remove(RecentTrees,1) end
    end

    local function GetBestTree()
        if #WorkingTrees==0 then return nil end
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
        local alive={}
        for _,e in ipairs(WorkingTrees) do
            if IsTreeAlive(e) then
                local bp=GetBodyPart(e.tree)
                if bp then
                    local dx=hrp.Position.X-bp.Position.X
                    local dz=hrp.Position.Z-bp.Position.Z
                    table.insert(alive,{entry=e,bp=bp,dist=math.sqrt(dx*dx+dz*dz)})
                end
            end
        end
        if #alive==0 then return nil end
        table.sort(alive,function(a,b) return a.dist<b.dist end)
        for _,c in ipairs(alive) do
            if not IsInHistory(c.entry.name) then return c.entry,c.bp,c.dist end
        end
        return alive[1].entry,alive[1].bp,alive[1].dist
    end

    -- Earnings watcher 1:1 из Woodcutter.txt
    local function SetupEarningsWatcher()
        task.spawn(function()
            local RS2=game:GetService("ReplicatedStorage")
            local stats=RS2:WaitForChild("Stats",30); if not stats then return end
            local ps=stats:WaitForChild(lp.Name,30); if not ps then return end
            local job=ps:WaitForChild("Job",30); if not job then return end
            local se=job:WaitForChild("ShiftEarnings",30); if not se then return end
            ShiftEarnings=se; LastEarnings=se.Value
            if earningsLbl then earningsLbl.Text="ShiftEarnings: "..tostring(se.Value); earningsLbl.TextColor3=C.grn end
            se:GetPropertyChangedSignal("Value"):Connect(function()
                local nv=se.Value
                if earningsLbl then earningsLbl.Text="ShiftEarnings: "..tostring(nv) end
                if AutofarmEnabled and WoodPhase=="working" and nv>LastEarnings then EarningsChanged=true end
                LastEarnings=nv
            end)
        end)
    end

    local function StopLoop()
        if WoodLoopThread then task.cancel(WoodLoopThread); WoodLoopThread=nil end; StopGlide()
    end

    local function StartLoop()
        StopLoop(); EarningsChanged=false; local startTime=tick()
        WoodLoopThread=task.spawn(function()
            while AutofarmEnabled and WoodPhase=="working" do
                if ShiftEarnings and ShiftEarnings.Value==0 and tick()-startTime>IGNORE_ZERO_DURATION then
                    SetStatus("Waiting...","Shift ended",Color3.fromRGB(235,160,25))
                    if treeLbl then treeLbl.Text="Waiting for shift..."; treeLbl.TextColor3=Color3.fromRGB(235,160,25) end
                    SafeGlide(WAIT_POS,60)
                    while AutofarmEnabled and WoodPhase=="working" do
                        task.wait(0.5)
                        if ShiftEarnings and ShiftEarnings.Value>0 then
                            LastEarnings=ShiftEarnings.Value; EarningsChanged=false
                            RecentTrees={}; startTime=tick(); ScanTrees(); break
                        end
                    end
                    if not AutofarmEnabled or WoodPhase~="working" then break end; continue
                end
                local entry,bp,dist=GetBestTree()
                if not entry then
                    SetStatus("Waiting...","All trees fell, waiting...",Color3.fromRGB(235,160,25))
                    if treeLbl then treeLbl.Text="Waiting respawn..."; treeLbl.TextColor3=Color3.fromRGB(235,160,25) end
                    task.wait(1); continue
                end
                local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not hrp then task.wait(1); continue end
                local goal=Vector3.new(bp.Position.X,hrp.Position.Y,bp.Position.Z)
                if treeLbl then treeLbl.Text=entry.name.." | "..string.format("%.0f",dist); treeLbl.TextColor3=C.txt2 end
                SetStatus("Gliding...","-> "..entry.name,Color3.fromRGB(235,160,25)); EarningsChanged=false
                if not SafeGlide(goal,60) then if not AutofarmEnabled then break end; task.wait(0.5); continue end
                if not AutofarmEnabled or WoodPhase~="working" then break end
                SetStatus("Chopping!","* "..entry.name,C.grn)
                while AutofarmEnabled and WoodPhase=="working" do
                    if EarningsChanged then EarningsChanged=false; AddToHistory(entry.name); break end
                    if not IsTreeAlive(entry) then AddToHistory(entry.name); break end
                    if ShiftEarnings and ShiftEarnings.Value==0 and tick()-startTime>IGNORE_ZERO_DURATION then break end
                    pcall(function() WoodRemote:FireServer({Tree=entry.tree}) end); task.wait(1)
                end
            end
        end)
    end

    -- Hook 1:1 из Woodcutter.txt
    local hookSetup=false
    local function SetupHook()
        if hookSetup then return end; hookSetup=true
        if not hookmetamethod then return end
        local old; old=hookmetamethod(game,"__namecall",function(self,...)
            local method=getnamecallmethod(); local args={...}
            if method=="FireServer" and AutofarmEnabled
            and WoodPhase=="wait_chop" and WoodRemote==nil then
                local payload=args[1]
                if type(payload)=="table" and payload.Tree~=nil then
                    local ok=pcall(function()
                        local sf=GetSpruceFolder()
                        assert(sf~=nil)
                        assert(payload.Tree:IsDescendantOf(sf))
                        assert(GetBodyPart(payload.Tree)~=nil)
                    end)
                    if ok then
                        WoodRemote=self; WoodPhase="working"
                        if remoteLbl then remoteLbl.Text="Chop remote: OK"; remoteLbl.TextColor3=C.grn end
                        Toast("Woodcutter","Remote saved!","ok")
                    end
                end
            end
            return old(self,...)
        end)
    end

    -- Phase watcher 1:1 из Woodcutter.txt
    local prevPhase=""
    RunService.Heartbeat:Connect(function()
        if WoodPhase~=prevPhase then
            prevPhase=WoodPhase
            if WoodPhase=="working" then
                if remoteLbl then remoteLbl.Text="Chop remote: OK"; remoteLbl.TextColor3=C.grn end
                StartLoop()
            end
            if WoodPhase=="idle" then SetStatus("Idle","",C.txt2) end
        end
        if not AutofarmEnabled and WoodPhase~="idle" then StopLoop(); WoodPhase="idle" end
    end)

    SetupEarningsWatcher()

    -- UI
    local y=8
    y=MakeSection(Col,"Woodcutter",y)
    y=MakeToggle(Col,"Enable Woodcutter",y,"WoodEnabled",function(v)
        AutofarmEnabled=v
        if v then
            SetupHook()
            task.spawn(function()
                if scanLbl then scanLbl.Text="Scanning..."; scanLbl.TextColor3=Color3.fromRGB(235,160,25) end
                ScanTrees()
            end)
            EarningsChanged=false; RecentTrees={}
            if ShiftEarnings then LastEarnings=ShiftEarnings.Value end
            if WoodRemote~=nil then WoodPhase="working"; SetStatus("Working!","Remote known!",C.grn)
            else WoodPhase="wait_chop"; SetStatus("Waiting...","Chop any Spruce Tree once!",Color3.fromRGB(235,160,25))
                Toast("Woodcutter","Chop any Spruce Tree once!","warn") end
            if treeLbl then treeLbl.Text="Tree: None"; treeLbl.TextColor3=C.txt2 end
        else StopLoop(); WoodPhase="idle"; SetStatus("Idle","",C.txt2); Toast("Woodcutter","Stopped","err") end
    end)
    y=MakeSection(Col,"Status",y)
    statusLbl,statusSub,y=MakeSBox(Col,y)
    scanLbl,y=MakeIBox(Col,"Scan: Not done",y)
    remoteLbl,y=MakeIBox(Col,"Chop remote: Not detected",y)
    treeLbl,y=MakeIBox(Col,"Tree: None",y)
    earningsLbl,y=MakeIBox(Col,"ShiftEarnings: ...",y)
    y=y+4
    y=MakeActionBtn(Col,"Re-Scan Trees",y,function()
        task.spawn(function()
            if scanLbl then scanLbl.Text="Scanning..."; scanLbl.TextColor3=Color3.fromRGB(235,160,25) end
            ScanTrees(); Toast("Scan","Done!","ok")
        end)
    end)
    y=MakeActionBtn(Col,"Reset Woodcutter",y,function()
        if AutofarmEnabled then Toast("Warning","Stop first!","err"); return end
        WoodRemote=nil; WoodPhase="idle"; RecentTrees={}; WorkingTrees={}
        if remoteLbl then remoteLbl.Text="Chop remote: Not detected"; remoteLbl.TextColor3=C.txt2 end
        if treeLbl then treeLbl.Text="Tree: None"; treeLbl.TextColor3=C.txt2 end
        if scanLbl then scanLbl.Text="Scan: Not done"; scanLbl.TextColor3=C.txt2 end
        SetStatus("Idle","",C.txt2); Toast("Reset","Done","ok")
    end)
    y=y+8; MakeHelpBox(Col,y)
end

