                local pos=GetModelPos(model); if not pos then continue end
                TeleportTo(pos); task.wait(0.3)
                if not AutofarmEnabled or MinerPhase~="working" then UnfreezePlayer(); break end
                FreezePlayer(); task.wait(0.3)
                if not AutofarmEnabled or MinerPhase~="working" then UnfreezePlayer(); break end
                local ok,err=pcall(function() MinerRemote:InvokeServer({P=Vector3.new(bx,by,bz)}) end)
                if not ok then UnfreezePlayer(); RemoteLost(); break end
                local waitStart=tick(); local remoteOk=true
                while AutofarmEnabled and MinerPhase=="working" do
                    task.wait(0.3); local f=FindOreFolder(); if not f then UnfreezePlayer(); break end
                    local m=GetOreModel(f,bx,by,bz); if not m or not m.Parent then break end
                    if IsRedOre(m) then pcall(function() m:Destroy() end); break end
                    if tick()-waitStart>=10 then
                        waitStart=tick(); local freshM=GetOreModel(f,bx,by,bz)
                        if freshM and freshM.Parent then
                            local freshPos=GetModelPos(freshM)
                            if freshPos then
                                UnfreezePlayer(); TeleportTo(freshPos); task.wait(0.3)
                                FreezePlayer(); task.wait(0.3)
                                local ok2,_=pcall(function() MinerRemote:InvokeServer({P=Vector3.new(bx,by,bz)}) end)
                                if not ok2 then UnfreezePlayer(); RemoteLost(); remoteOk=false; break end
                            end
                        end
                    end
                end
                if not remoteOk then break end
            end
            UnfreezePlayer()
        end)
    end
    local hookSetup=false
    local function SetupHook()
        if hookSetup then return end; hookSetup=true
        if not hookmetamethod then return end
        local old; old=hookmetamethod(game,"__namecall",function(self,...)
            local method=getnamecallmethod(); local args={...}
            if method=="InvokeServer" and AutofarmEnabled
            and MinerPhase=="wait_trigger" and MinerRemote==nil then
                local payload=args[1]
