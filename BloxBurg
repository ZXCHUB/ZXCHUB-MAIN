end
    local function GetOreModel(folder,x,y,z)
        if not folder then return nil end
        return folder:FindFirstChild(tostring(x)..":"..tostring(y)..":"..tostring(z))
    end
    local function GetModelPos(model)
        if not model then return nil end
        if model:IsA("BasePart") then return model.Position end
        if model:IsA("Model") then
            if model.PrimaryPart then return model.PrimaryPart.Position end
            local ok,piv=pcall(function() return model:GetPivot() end); if ok then return piv.Position end
            local bp=model:FindFirstChildOfClass("BasePart"); if bp then return bp.Position end
        end
