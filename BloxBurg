-- SHARED GLIDE
-- ════════════════════════════════════════════════════════
local GlideConn=nil
local function StopGlide()
    if GlideConn then GlideConn:Disconnect(); GlideConn=nil end
    local hum=lp.Character and lp.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed=16; hum.JumpPower=50 end
    if lp.Character then
        for _,p in pairs(lp.Character:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=true end
        end
    end
end
local function GlideTo(targetPos,speed,onDone)
    StopGlide(); speed=speed or 50
    local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then if onDone then onDone() end; return end
    local hum=lp.Character:FindFirstChildOfClass("Humanoid"); if hum then hum.WalkSpeed=0 end
    for _,p in pairs(lp.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide=false end end
    GlideConn=RunService.Heartbeat:Connect(function(dt)
        local h=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not h then StopGlide(); return end
        local dir=targetPos-h.Position; local dist=dir.Magnitude
        if dist<1.5 then StopGlide(); if onDone then onDone() end
        else local step=math.min(speed*dt,dist); h.CFrame=CFrame.new(h.Position+dir.Unit*step)*(h.CFrame-h.Position) end
    end)
end
local function SafeGlide(pos,speed,enabledRef)
    if enabledRef and not enabledRef[1] then StopGlide(); return false end
    local done=false
    GlideTo(pos,speed,function() done=true end)
    local t=tick()
    while not done do
        task.wait(0.05); if tick()-t>40 then StopGlide(); return false end
        if enabledRef and not enabledRef[1] then StopGlide(); return false end
    end
    return true
end

