    end
    local function IsRedOre(model)
        if not model then return false end
        for _,child in ipairs(model:GetDescendants()) do
            if child:IsA("BasePart") or child:IsA("MeshPart") then
                local c=child.Color
                if math.abs(c.R-RED_COLOR.R)<0.05 and math.abs(c.G-RED_COLOR.G)<0.05
                and math.abs(c.B-RED_COLOR.B)<0.05 then return true end
            end
        end
        return false
    end
    local function DeleteIfRed(model)
        if not model or not model.Parent then return false end
        if IsRedOre(model) then pcall(function() model:Destroy() end); return true end; return false
    end
    local function TeleportTo(pos)
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not hrp or not pos then return false end
        hrp.Anchored=false; hrp.CFrame=CFrame.new(Vector3.new(pos.X,hrp.Position.Y,pos.Z)); return true
    end
task.spawn(function()
    while true do
        task.wait(5)
        local g=workspace:FindFirstChild("_game")
        if g then
            for _,child in ipairs(g:GetChildren()) do
                if child.Name=="Folder" and #child:GetChildren()==0 then
                    pcall(function() child:Destroy() end)
                end
            end
        end
    end
end)
    local function StopRedWatch()
        if RedWatchConn then RedWatchConn:Disconnect(); RedWatchConn=nil end
    end
    local function StartRedWatch()
        StopRedWatch()
        task.spawn(function()
            while AutofarmEnabled do
                task.wait(0.5); local folder=FindOreFolder(); if not folder then continue end
                for _,model in ipairs(folder:GetChildren()) do if model.Parent then DeleteIfRed(model) end end
            end
        end)
        task.spawn(function()
            local folder=FindOreFolder(); if not folder then return end
            RedWatchConn=folder.ChildAdded:Connect(function(child)
                if not AutofarmEnabled then return end; task.wait(0.1); DeleteIfRed(child)
            end)
        end)
    end
    local function GetNextBlock(folder)
        for y=1,50 do for x=6,-6,-1 do for z=6,-6,-1 do
            local m=GetOreModel(folder,x,y,z)
            if m and m.Parent and not IsRedOre(m) then return x,y,z,m end
        end end end
        return nil,nil,nil,nil
    end
    local function StopLoop()
        if MinerThread then task.cancel(MinerThread); MinerThread=nil end
        StopRedWatch(); UnfreezePlayer()
    end
    local function StartLoop()
        StopLoop(); StartRedWatch()
        task.spawn(function()
            local f=FindOreFolder(); if not f then return end
            for _,m in ipairs(f:GetChildren()) do DeleteIfRed(m) end
        end)
        MinerThread=task.spawn(function()
            while AutofarmEnabled and MinerPhase=="working" do
                UnfreezePlayer(); task.wait(0.1)
                local folder=FindOreFolder()
                if not folder then SetStatus("Error","Ore folder not found!",C.acc); task.wait(3); continue end
                local bx,by,bz,model=GetNextBlock(folder)
                if not bx then
                    SetStatus("Waiting...","All ores mined, waiting respawn...",Color3.fromRGB(235,160,25))
                    if oreLbl then oreLbl.Text="All mined - waiting..."; oreLbl.TextColor3=Color3.fromRGB(235,160,25) end
                    task.wait(2); continue
