local function BuildJanitorTab()
    local P=MakePage(); local S=MakeScroll(P)
    local Col=Frame(S,UDim2.new(1,-16,0,1),UDim2.new(0,8,0,0),C.bg0)
    Col.BackgroundTransparency=1; Col.AutomaticSize=Enum.AutomaticSize.Y

    local JanitorRemote=nil; local JanitorPhase="idle"
    local AutofarmEnabled=false; local JanitorThread=nil
    local statusLbl,statusSub,remoteLbl,spawnLbl

    local function SetStatus(m,s,c)
        if statusLbl then statusLbl.Text="Status: "..m; statusLbl.TextColor3=c or C.txt2 end
        if statusSub then statusSub.Text=s or "" end
    end
    local function GetSpawnsFolder()
        local env=workspace:FindFirstChild("Environment"); if not env then return nil end
        local locs=env:FindFirstChild("Locations"); if not locs then return nil end
        local sa=locs:FindFirstChild("SchoolArea"); if not sa then return nil end
        local sch=sa:FindFirstChild("School"); if not sch then return nil end
        return sch:FindFirstChild("JanitorSpawns")
    end
    local function GetSpawnPos(spawn)
        if spawn:IsA("BasePart") then return spawn.Position end
        if spawn:IsA("Model") then
            if spawn.PrimaryPart then return spawn.PrimaryPart.Position end
            local ok,piv=pcall(function() return spawn:GetPivot() end); if ok then return piv.Position end
            local bp=spawn:FindFirstChildOfClass("BasePart"); if bp then return bp.Position end
        end
        return nil
    end
    local function GetDirtySpawns()
        local folder=GetSpawnsFolder(); if not folder then return {} end
        local dirty={}
        for _,spawn in ipairs(folder:GetChildren()) do
            if spawn.Name=="GroundSpawn" and #spawn:GetChildren()>0 then table.insert(dirty,spawn) end
        end
        return dirty
    end
    local function GetNearestSpawn(spawns)
        local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
        local best,bestDist=nil,math.huge
        for _,spawn in ipairs(spawns) do
            local pos=GetSpawnPos(spawn)
            if pos then local d=(hrp.Position-pos).Magnitude; if d<bestDist then bestDist=d; best=spawn end end
        end
        return best
    end
    local function StopLoop()
        if JanitorThread then task.cancel(JanitorThread); JanitorThread=nil end; StopGlide()
    end
    local function StartLoop()
        StopLoop()
        JanitorThread=task.spawn(function()
            while AutofarmEnabled and JanitorPhase=="working" do
                local dirty=GetDirtySpawns()
                if #dirty==0 then
                    SetStatus("Waiting...","No dirty spawns...",Color3.fromRGB(235,160,25))
                    if spawnLbl then spawnLbl.Text="Dirty: 0 - waiting..."; spawnLbl.TextColor3=Color3.fromRGB(235,160,25) end
                    while AutofarmEnabled and JanitorPhase=="working" do
                        task.wait(0.5); if #GetDirtySpawns()>0 then break end
                    end
                    if not AutofarmEnabled or JanitorPhase~="working" then break end; continue
                end
                local target=GetNearestSpawn(dirty); if not target then task.wait(1); continue end
                local targetPos=GetSpawnPos(target); if not targetPos then task.wait(1); continue end
                local hrp=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart"); if not hrp then task.wait(1); continue end
                local goal=Vector3.new(targetPos.X,hrp.Position.Y,targetPos.Z)
                SetStatus("Gliding...","-> "..target.Name,Color3.fromRGB(235,160,25))
                if spawnLbl then spawnLbl.Text=#dirty.." | -> "..target.Name; spawnLbl.TextColor3=Color3.fromRGB(235,160,25) end
                local done=false; GlideTo(goal,60,function() done=true end); local gt=tick()
                while not done and AutofarmEnabled do task.wait(0.05); if tick()-gt>40 then StopGlide(); break end end
                if not AutofarmEnabled or JanitorPhase~="working" then break end
                SetStatus("Cleaning!","Cleaning: "..target.Name,C.grn)
                if spawnLbl then spawnLbl.Text="Cleaning: "..target.Name; spawnLbl.TextColor3=C.grn end
                while AutofarmEnabled and JanitorPhase=="working" do
                    if #target:GetChildren()==0 then break end
                    pcall(function() JanitorRemote:InvokeServer({Spawn=target}) end)
                    local ws=tick()
                    while AutofarmEnabled and JanitorPhase=="working" do
                        task.wait(0.2); if #target:GetChildren()==0 then break end
                        if tick()-ws>=1 then break end
                    end
                    if #target:GetChildren()==0 then break end
                end
            end
        end)
    end
    local hookSetup=false
    local function SetupHook()
        if hookSetup then return end; hookSetup=true
        if not hookmetamethod then return end
        local old; old=hookmetamethod(game,"__namecall",function(self,...)
            local method=getnamecallmethod(); local args={...}
            if method=="InvokeServer" and AutofarmEnabled
            and JanitorPhase=="wait_trigger" and JanitorRemote==nil then
                local payload=args[1]
                if type(payload)=="table" and payload.Spawn~=nil then
                    local ok=pcall(function()
                        local folder=GetSpawnsFolder()
                        assert(folder~=nil)
                        assert(payload.Spawn.Name=="GroundSpawn")
                        assert(payload.Spawn:IsDescendantOf(folder))
                    end)
                    if ok then
                        JanitorRemote=self; JanitorPhase="working"
                        if remoteLbl then remoteLbl.Text="Remote: OK"; remoteLbl.TextColor3=C.grn end
                        Toast("Janitor","Remote saved!","ok")
                    end
                end
            end
            return old(self,...)
        end)
    end
    local prevPhase=""
    RunService.Heartbeat:Connect(function()
        if JanitorPhase~=prevPhase then
            prevPhase=JanitorPhase
            if JanitorPhase=="working" then
                if remoteLbl then remoteLbl.Text="Remote: OK"; remoteLbl.TextColor3=C.grn end
                StartLoop()
            end
            if JanitorPhase=="idle" then SetStatus("Idle","",C.txt2) end
        end
        if not AutofarmEnabled and JanitorPhase~="idle" then StopLoop(); JanitorPhase="idle" end
    end)
    local y=8
    y=MakeSection(Col,"Janitor",y)
    y=MakeToggle(Col,"Enable Janitor",y,"JanitorEnabled",function(v)
        AutofarmEnabled=v
        if v then
            SetupHook()
            if JanitorRemote~=nil then JanitorPhase="working"; SetStatus("Working!","Starting!",C.grn)
            else JanitorPhase="wait_trigger"; SetStatus("Waiting...","Clean one dirty spawn!",Color3.fromRGB(235,160,25))
                Toast("Janitor","Clean one spawn manually!","warn") end
        else StopLoop(); JanitorPhase="idle"; SetStatus("Idle","",C.txt2); Toast("Janitor","Stopped","err") end
    end)
    y=MakeSection(Col,"Status",y)
    statusLbl,statusSub,y=MakeSBox(Col,y)
    remoteLbl,y=MakeIBox(Col,"Remote: Not detected",y)
    spawnLbl,y=MakeIBox(Col,"Dirty spawns: -",y)
    y=y+4
    y=MakeActionBtn(Col,"Reset Janitor",y,function()
        if AutofarmEnabled then Toast("Warning","Stop first!","err"); return end
        JanitorRemote=nil; JanitorPhase="idle"
        if remoteLbl then remoteLbl.Text="Remote: Not detected"; remoteLbl.TextColor3=C.txt2 end
        if spawnLbl then spawnLbl.Text="Dirty spawns: -"; spawnLbl.TextColor3=C.txt2 end
        SetStatus("Idle","",C.txt2); Toast("Reset","Done","ok")
    end)
    y=y+8; MakeHelpBox(Col,y)
end

