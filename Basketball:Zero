-- Платформа 2000x2000
local floatPlatform
local function toggleFloat()
    if settings.NeverLoseBall then
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = player.Character.HumanoidRootPart
            local pos = hrp.Position + Vector3.new(0, 50, 0)

            floatPlatform = Instance.new("Part")
            floatPlatform.Size = Vector3.new(2000, 1, 2000)
            floatPlatform.Position = pos
            floatPlatform.Anchored = true
            floatPlatform.CanCollide = true
            floatPlatform.Transparency = 1
            floatPlatform.Parent = workspace

            hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        end
    else
        if floatPlatform then floatPlatform:Destroy() end
    end
end

-- Бинды
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == settings.Bind_TeleportToBall and settings.TeleportToBall then
        if basketball then
            player.Character.HumanoidRootPart.CFrame = basketball.CFrame + Vector3.new(0, 5, 0)
        end
    end
    if input.KeyCode == settings.Bind_NeverLoseBall then
        toggleFloat()
    end
    if input.KeyCode == settings.Bind_HomeHop and settings.HomeHop then
        if timer1 then
            player.Character.HumanoidRootPart.CFrame = timer1.CFrame + Vector3.new(0, 5, 0)
        end
    end
    if input.KeyCode == settings.Bind_AwayHop and settings.AwayHop then
        if timer2 then
            player.Character.HumanoidRootPart.CFrame = timer2.CFrame + Vector3.new(0, 5, 0)
        end
    end
end)

-- Respawn
player.CharacterAdded:Connect(function(char)
    char:WaitForChild("Humanoid")
    if settings.NeverLoseBall then
        toggleFloat()
    end
end)

-- Toggle GUI
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.RightShift then
        guiVisible = not guiVisible
        main.Visible = guiVisible
    end
end)

