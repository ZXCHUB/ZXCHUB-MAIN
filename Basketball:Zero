local function updateActive()
    local acts = {}
    if settings.TeleportToBall then table.insert(acts, "TP Ball") end
    if settings.NeverLoseBall then table.insert(acts, "No Lose") end
    if settings.HomeHop then table.insert(acts, "Home Hop") end
    if settings.AwayHop then table.insert(acts, "Away Hop") end
    activeLabel.Text = "Active: " .. (#acts > 0 and table.concat(acts, " • ") or "None")
end

local function createFeature(name, posY, toggleKey, bindKey)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0.9, 0, 0, 50)
    toggle.Position = UDim2.new(0.05, 0, posY, 0)
    toggle.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    toggle.Text = name .. ": OFF"
    toggle.TextColor3 = Color3.new(1,1,1)
    toggle.TextSize = 20
    toggle.Font = Enum.Font.GothamSemibold
    toggle.Parent = contentFrame

    toggle.MouseButton1Click:Connect(function()
        settings[toggleKey] = not settings[toggleKey]
        toggle.Text = name .. ": " .. (settings[toggleKey] and "ON" or "OFF")
        toggle.BackgroundColor3 = settings[toggleKey] and Color3.fromRGB(50, 150, 80) or Color3.fromRGB(35, 35, 55)
        updateActive()
    end)

    local bindBtn = Instance.new("TextButton")
    bindBtn.Size = UDim2.new(0.9, 0, 0, 50)
    bindBtn.Position = UDim2.new(0.05, 0, posY + 0.13, 0)
    bindBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
    bindBtn.Text = "Bind " .. name .. ": " .. settings[bindKey].Name
    bindBtn.TextColor3 = Color3.new(1,1,1)
    bindBtn.TextSize = 18
    bindBtn.Font = Enum.Font.Gotham
    bindBtn.Parent = contentFrame

    bindBtn.MouseButton1Click:Connect(function()
        bindBtn.Text = "Press any key..."
        local conn
        conn = UserInputService.InputBegan:Connect(function(input)
            if input.KeyCode ~= Enum.KeyCode.Unknown then
                settings[bindKey] = input.KeyCode
                bindBtn.Text = "Bind " .. name .. ": " .. input.KeyCode.Name
                conn:Disconnect()
            end
        end)
    end)
end

createFeature("Teleport to Ball", 0.05, "TeleportToBall", "Bind_TeleportToBall")
