local function ApplyTheme(themeName)
    local newTheme = Themes[themeName]
    if not newTheme then return end
    local oldTheme = C; C = newTheme
    for _, obj in ipairs(GUI:GetDescendants()) do
        pcall(function()
            for key, oldColor in pairs(oldTheme) do
                if obj:IsA("GuiObject") and obj.BackgroundColor3 == oldColor then obj.BackgroundColor3 = newTheme[key] end
                if (obj:IsA("TextLabel") or obj:IsA("TextBox") or obj:IsA("TextButton")) and obj.TextColor3 == oldColor then obj.TextColor3 = newTheme[key] end
                if obj:IsA("UIStroke") and obj.Color == oldColor then obj.Color = newTheme[key] end
            end
        end)
    end
end

