local UnsupportedFunctions = {}
local AllFunctions         = {}

local function CheckFunction(name, fn, impact, category)
    local supported = (fn ~= nil)
    table.insert(AllFunctions, { name = name, impact = impact, category = category or "Other", supported = supported })
    if not supported then
        table.insert(UnsupportedFunctions, { name = name, impact = impact, category = category or "Other" })
    end
end

