    local fill  = Frame(track, UDim2.new(0, 0, 1, 0), UDim2.new(0, 0, 0, 0), C.acc, 3)
    local thumb = Frame(track, UDim2.new(0, isMobile and 16 or 14, 0, isMobile and 16 or 14),
        UDim2.new(0, -7, 0.5, isMobile and -8 or -7), C.white, 8); Stroke(thumb, C.brd2, 1)
    local isDrag = false
    local function SetVal(v)
        Flags[flag] = math.clamp(math.floor(v + 0.5), minV, maxV)
        local pct = (Flags[flag] - minV) / (maxV - minV)
        fill.Size = UDim2.new(pct, 0, 1, 0); thumb.Position = UDim2.new(pct, -7, 0.5, isMobile and -8 or -7)
        valL.Text = fmt and string.format(fmt, Flags[flag]) or tostring(Flags[flag])
        if callback then callback(Flags[flag]) end
    end
    SetVal(Flags[flag] or minV); Setters[flag] = function(v) SetVal(v) end
    local function PosToVal(absX) return minV + (maxV - minV) * math.clamp((absX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1) end
    track.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDrag = true; SetVal(PosToVal(i.Position.X)) end end)
    thumb.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDrag = true end end)
    UIS.InputChanged:Connect(function(i) if isDrag and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then SetVal(PosToVal(i.Position.X)) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then isDrag = false end end)
    return yOff + (isMobile and 60 or 56)
end

local function MakeInput(parent, text, placeholder, yOff, flag, callback)
    local cont = Frame(parent, UDim2.new(1, -32, 0, 52), UDim2.new(0, 16, 0, yOff), C.bg0)
    cont.BackgroundTransparency = 1
    Lbl(cont, text, isMobile and 13 or 12, C.txt, Enum.Font.Gotham).Size = UDim2.new(1, 0, 0, isMobile and 22 or 18)
    local box = Instance.new("TextBox", cont)
    local boxH = isMobile and 30 or 26
    box.Size = UDim2.new(1, 0, 0, boxH); box.Position = UDim2.new(0, 0, 0, isMobile and 22 or 20)
    box.BackgroundColor3 = C.bg3; box.BorderSizePixel = 0
    box.Font = Enum.Font.GothamMedium; box.TextSize = isMobile and 13 or 12
    box.TextColor3 = C.txt; box.PlaceholderColor3 = C.txt3
    box.PlaceholderText = placeholder; box.Text = Flags[flag] or ""
    box.TextXAlignment = Enum.TextXAlignment.Left; box.ClearTextOnFocus = false
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    Instance.new("UIPadding", box).PaddingLeft = UDim.new(0, 8)
    local st = Stroke(box, C.brd2, 1)
    Setters[flag] = function(v) Flags[flag] = v; box.Text = v end
    box:GetPropertyChangedSignal("Text"):Connect(function() Flags[flag] = box.Text; if callback then callback(box.Text) end end)
    box.Focused:Connect(function() st.Color = C.acc end)
    box.FocusLost:Connect(function() st.Color = C.brd2 end)
    return yOff + (isMobile and 60 or 54), box
end

local function MakeActionBtn(parent, text, yOff, callback)
    local bH = isMobile and 34 or 28
    local b = Btn(parent, UDim2.new(1, -32, 0, bH), UDim2.new(0, 16, 0, yOff), C.bg3, 4)
