local ActiveToasts = {}
local function Toast(title, msg, kind)
    local col = kind == "err" and C.acc or kind == "ok" and C.grn or (kind == "warn" and Color3.fromRGB(255, 170, 0) or C.txt2)
    local toastW = isMobile and 240 or 260
    local t = Frame(GUI, UDim2.new(0, toastW, 0, 56), UDim2.new(1, 20, 0, 20), C.bg0, 6)
    t.ClipsDescendants = true; Stroke(t, C.brd2, 1)
    Frame(t, UDim2.new(0, 3, 1, 0), UDim2.new(0, 0, 0, 0), col, 2)
    local titleLbl = Lbl(t, title, isMobile and 12 or 13, C.white, Enum.Font.GothamBold)
    titleLbl.Size = UDim2.new(1, -20, 0, 18); titleLbl.Position = UDim2.new(0, 14, 0, 8)
    local msgLbl = Lbl(t, msg, isMobile and 10 or 11, C.txt2, Enum.Font.Gotham)
    msgLbl.Size = UDim2.new(1, -20, 0, 18); msgLbl.Position = UDim2.new(0, 14, 0, 28)
    msgLbl.TextTruncate = Enum.TextTruncate.AtEnd
    table.insert(ActiveToasts, t)
    local function UpdateToasts()
        local yOffset = 20
        for i = 1, #ActiveToasts do
            TweenS:Create(ActiveToasts[i], TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                {Position = UDim2.new(1, -(toastW + 20), 0, yOffset)}):Play()
            yOffset = yOffset + 64
        end
    end
    UpdateToasts()
    task.delay(4, function()
        local idx = table.find(ActiveToasts, t)
        if idx then table.remove(ActiveToasts, idx); UpdateToasts() end
        TweenS:Create(t, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            {Position = UDim2.new(1, 20, 0, t.Position.Y.Offset)}):Play()
        task.delay(0.3, function() t:Destroy() end)
    end)
end

