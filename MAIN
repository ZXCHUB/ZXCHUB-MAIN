-- ════════════════════════════════════════
-- SAVE / LOAD  (12-hour bypass)
-- ════════════════════════════════════════
local function getTime()
    return os.time()
end

local function saveKeyTime()
    pcall(function()
        if writefile then
            writefile(SAVE_FILE, HttpService:JSONEncode({
                savedAt = getTime()
            }))
        end
    end)
end

local function isKeySaved()
    local ok = false
    pcall(function()
        if isfile and isfile(SAVE_FILE) then
            local data = HttpService:JSONDecode(readfile(SAVE_FILE))
            if data and data.savedAt then
                local elapsed = getTime() - data.savedAt
                -- 12 часов = 43200 секунд
                if elapsed < (KEY_EXPIRE_HOURS * 3600) then
                    ok = true
                else
                    -- истёк — удаляем
                    if delfile then pcall(delfile, SAVE_FILE) end
                end
            end
        end
    end)
    return ok
end

-- ════════════════════════════════════════
-- LOAD GAME
-- ════════════════════════════════════════
local function loadGame(sg, overlay)
    local fi = TweenInfo.new(0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    for _, v in ipairs(sg:GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") or v:IsA("TextBox") then
            TweenService:Create(v, fi, {TextTransparency=1}):Play()
        end
        if v:IsA("Frame") or v:IsA("ImageLabel") then
            TweenService:Create(v, fi, {BackgroundTransparency=1}):Play()
        end
    end
    TweenService:Create(overlay, fi, {BackgroundTransparency=1}):Play()
    task.wait(0.5)
    sg:Destroy()

    local scriptUrl = supportedGames[game.PlaceId]
    if scriptUrl then
        local ok, err = pcall(function()
            loadstring(game:HttpGet(scriptUrl, true))()
        end)
        if not ok then
            warn("[ZXCHub] Failed to load: " .. tostring(err))
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "ZXCHub", Text = "Failed to load script", Duration = 10,
            })
        end
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "ZXCHub", Text = "Game not supported yet!", Duration = 10,
        })
    end
end

