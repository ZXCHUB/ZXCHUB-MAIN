-- ════════════════════════════════════════
-- CHECK KEY
-- ════════════════════════════════════════
local function checkKey()
    local key = input.Text:match("^%s*(.-)%s*$")
    if key == "" then
        statusLbl.Text = "✗ Please enter a key first"
        statusLbl.TextColor3 = Color3.fromRGB(255,80,80)
        return
    end

    -- Dev bypass
    if VALID_KEYS[key] then
        statusLbl.Text = ""
        checkBtn.Text = "✓ Loading..."
        checkBtn.BackgroundColor3 = Color3.fromRGB(25,80,45)
        saveKeyTime()
        task.wait(0.6)
        loadGame(sg, overlay)
        return
    end

    statusLbl.Text = "Checking..."
    statusLbl.TextColor3 = Color3.fromRGB(160,120,220)

    -- Work.ink API
    local apiUrl = "https://work.ink/_api/v2/token/isValid/" .. HttpService:UrlEncode(key)
    local ok, response = pcall(function()
        return game:HttpGet(apiUrl, true)
    end)

    if not ok then
        statusLbl.Text = "✗ Connection error, try again"
        statusLbl.TextColor3 = Color3.fromRGB(255,80,80)
        TweenService:Create(cardStroke,TweenInfo.new(0.1),{Color=Color3.fromRGB(200,50,50)}):Play()
        task.delay(0.5, function()
            TweenService:Create(cardStroke,TweenInfo.new(0.3),{Color=Color3.fromRGB(95,35,175)}):Play()
        end)
        return
    end

    local decOk, data = pcall(function() return HttpService:JSONDecode(response) end)

    if decOk and data and data.valid == true then
        statusLbl.Text = ""
        checkBtn.Text = "✓ Loading..."
        checkBtn.BackgroundColor3 = Color3.fromRGB(25,80,45)
        saveKeyTime()  -- сохраняем время — 12 часов не будет спрашивать
        task.wait(0.6)
        loadGame(sg, overlay)
    else
        statusLbl.Text = "✗ Invalid key — join discord for key!"
        statusLbl.TextColor3 = Color3.fromRGB(255,80,80)
        TweenService:Create(cardStroke,TweenInfo.new(0.1),{Color=Color3.fromRGB(200,50,50)}):Play()
        task.delay(0.5, function()
            TweenService:Create(cardStroke,TweenInfo.new(0.3),{Color=Color3.fromRGB(95,35,175)}):Play()
        end)
    end
end

checkBtn.MouseButton1Click:Connect(checkKey)
input.FocusLost:Connect(function(enter) if enter then checkKey() end end)

