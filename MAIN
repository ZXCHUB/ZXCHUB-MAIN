-- BYPASS — если ключ уже сохранён
-- ════════════════════════════════════════
if isKeySaved() then
    -- Показываем короткое уведомление и сразу грузим
    local playerGui = lp:WaitForChild("PlayerGui")
    local guiParent = (gethui and gethui()) or playerGui

    local sg2 = Instance.new("ScreenGui")
    sg2.Name = "ZXCHubKey"; sg2.ResetOnSpawn = false
    sg2.IgnoreGuiInset = true; sg2.DisplayOrder = 1000
    sg2.Parent = guiParent

    local overlay2 = Instance.new("Frame", sg2)
    overlay2.Size = UDim2.fromScale(1,1)
    overlay2.BackgroundColor3 = Color3.fromRGB(4,3,10)
    overlay2.BackgroundTransparency = 0.5
    overlay2.BorderSizePixel = 0

    local notif = Instance.new("Frame", sg2)
    notif.Size = UDim2.fromOffset(300, 60)
    notif.AnchorPoint = Vector2.new(0.5, 0.5)
    notif.Position = UDim2.fromScale(0.5, 0.5)
    notif.BackgroundColor3 = Color3.fromRGB(11,9,18)
    notif.BorderSizePixel = 0
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0,12)
    local ns = Instance.new("UIStroke", notif)
    ns.Color = Color3.fromRGB(95,35,175); ns.Thickness = 1.5

    local nl = Instance.new("TextLabel", notif)
    nl.Size = UDim2.fromScale(1,1)
    nl.BackgroundTransparency = 1
    nl.Text = "✓ Key valid — loading..."
    nl.TextColor3 = Color3.fromRGB(120,255,150)
    nl.TextSize = 15; nl.Font = Enum.Font.GothamBold

    -- Считаем сколько времени осталось
    pcall(function()
        if isfile and isfile(SAVE_FILE) then
            local data = HttpService:JSONDecode(readfile(SAVE_FILE))
            if data and data.savedAt then
                local remaining = math.max(0, (KEY_EXPIRE_HOURS * 3600) - (getTime() - data.savedAt))
                local h = math.floor(remaining / 3600)
                local m = math.floor((remaining % 3600) / 60)
                nl.Text = string.format("✓ Key valid  —  %dh %dm left", h, m)
            end
        end
    end)

    task.wait(1.2)
    loadGame(sg2, overlay2)
    return
end

